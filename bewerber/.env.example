# OpenAI API key for LLM calls (gpt-5.1-mini)
OPENAI_API_KEY=sk-...

# Optional fallback chain when primary OpenAI quota / API is exhausted.
# Order of attempts: OPENAI_API_KEY -> OPENAI_API_KEY_FALLBACK -> GOOGLE_API_KEY
OPENAI_API_KEY_FALLBACK=
GOOGLE_API_KEY=

# Optional: override default models
BEWERBER_LLM_MODEL=gpt-5.1-mini
BEWERBER_GEMINI_MODEL=gemini-2.0-flash-exp

# Arbeitsagentur API key (for Plan B; not needed for Plan A)
ARBEITSAGENTUR_API_KEY=
