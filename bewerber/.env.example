# OpenAI API key for LLM calls (gpt-5.1-mini)
OPENAI_API_KEY=sk-...

# Optional fallback chain when primary OpenAI quota / API is exhausted.
# Order of attempts: OPENAI_API_KEY -> OPENAI_API_KEY_FALLBACK -> GOOGLE_API_KEY
OPENAI_API_KEY_FALLBACK=
GOOGLE_API_KEY=

# LLM-Modell-Konfiguration. Resolution-Kette pro Role:
#   BEWERBER_SCORING_MODEL    -> BEWERBER_LLM_MODEL -> gpt-5.1-mini  (Default)
#   BEWERBER_GENERATION_MODEL -> BEWERBER_LLM_MODEL -> gpt-5.1-mini  (Default)
#
# Scoring = pro Job ein Call mit ~14K Tokens master_profile als Input.
# Klassifikations-Task -> 'mini' Variante reicht problemlos.
#
# Generation = Anschreiben + Customize beim Tailor-Lauf. Qualitaets-kritisch
# (kreatives Schreiben, kein Erfinden von Skills). 'mini' reicht hier
# meist NICHT - Vollmodell behalten.
BEWERBER_SCORING_MODEL=gpt-5.1-mini
BEWERBER_GENERATION_MODEL=gpt-5.1

# Legacy-Fallback. Wenn die zwei Role-Vars oben nicht gesetzt sind,
# verwenden beide Rollen diesen Wert. Default: gpt-5.1-mini.
BEWERBER_LLM_MODEL=gpt-5.1-mini

# Gemini-Modell fuer die Fallback-Provider-Chain (siehe llm.py).
BEWERBER_GEMINI_MODEL=gemini-2.0-flash-exp

# Arbeitsagentur API key (for Plan B; not needed for Plan A)
ARBEITSAGENTUR_API_KEY=
