# --- API Keys ---------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_API_KEY_FALLBACK=          # optional: zweiter OpenAI-Account
GOOGLE_API_KEY=                    # optional: aktiviert Gemini-Provider

# --- LLM-Provider-Konfiguration ---------------------------------------------
# Jede Rolle (SCORING / GENERATION) hat drei unabhaengige Achsen:
#
#   PROVIDER_ORDER  Reihenfolge der Fallback-Kette. Komma-getrennt.
#                   Erlaubt: openai, gemini   Default: "openai,gemini"
#
#   OPENAI_MODEL    Model fuer beide OpenAI-Provider (primary + fallback key).
#                   Resolution:  ROLE-spez -> BEWERBER_LLM_MODEL -> gpt-5-mini
#
#   GEMINI_MODEL    Model fuer den Gemini-Provider.
#                   Resolution:  ROLE-spez -> BEWERBER_GEMINI_MODEL
#                                          -> gemini-2.5-flash
#
# Jeder Provider in der Kette bekommt seinen EIGENEN Model-Namen - es ist
# explizit nicht moeglich, OpenAI mit einem Gemini-Model-Namen aufzurufen.

# Scoring = pro Job ein Call mit ~14K Tokens master_profile. Hohe Frequenz,
# Klassifikations-Task. Gemini-2.0-flash ist im Free Tier -> primaer guenstig.
BEWERBER_SCORING_PROVIDER_ORDER=gemini,openai
BEWERBER_SCORING_OPENAI_MODEL=gpt-5-mini
BEWERBER_SCORING_GEMINI_MODEL=gemini-2.5-flash

# Generation = Anschreiben + Customize, kreatives Schreiben mit Faktentreue.
# Niedrige Frequenz (1-2 Calls pro Tailor-Lauf), Qualitaets-kritisch.
# -> OpenAI gpt-5.1 als primary, Gemini nur als Notnagel.
BEWERBER_GENERATION_PROVIDER_ORDER=openai,gemini
BEWERBER_GENERATION_OPENAI_MODEL=gpt-5.1
BEWERBER_GENERATION_GEMINI_MODEL=gemini-2.5-flash

# Legacy-Fallbacks - werden nur benutzt, wenn die Role-spezifischen Vars oben
# NICHT gesetzt sind. Dienen vor allem Tests und alten Konfigs.
BEWERBER_LLM_MODEL=gpt-5-mini
BEWERBER_GEMINI_MODEL=gemini-2.5-flash

# --- Datenquellen -----------------------------------------------------------
ARBEITSAGENTUR_API_KEY=
