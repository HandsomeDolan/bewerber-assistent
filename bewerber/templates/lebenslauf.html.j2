{# Macros: deutsche Monatsformatierung "2026-01" → "Jan 2026" #}
{%- set MONATE_DE = ["", "Jan", "Feb", "Mär", "Apr", "Mai", "Jun", "Jul", "Aug", "Sep", "Okt", "Nov", "Dez"] -%}
{%- macro fmt_ym(s) -%}
{%- if not s -%}{%- else -%}
{%- set parts = s.split("-") -%}
{%- if parts | length == 2 -%}{{ MONATE_DE[parts[1] | int] }} {{ parts[0] }}{%- else -%}{{ s }}{%- endif -%}
{%- endif -%}
{%- endmacro -%}
{%- macro fmt_year(s) -%}
{%- if not s -%}{%- else -%}{{ s.split("-")[0] }}{%- endif -%}
{%- endmacro -%}
<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8">
<title>Lebenslauf {{ profile.person.name }}</title>
<style>
@page {
  size: A4;
  margin: 1.8cm 2cm 1.5cm 2cm;
  @bottom-right { content: "Seite " counter(page) " von " counter(pages); font-size: 8.5pt; color: #888; }
}
* { box-sizing: border-box; }
body {
  font-family: "Helvetica Neue", "Arial", "Liberation Sans", sans-serif;
  font-size: 10pt;
  line-height: 1.45;
  color: #1a1a1a;
  margin: 0;
}
.header { text-align: center; margin-bottom: 4pt; }
.name {
  font-size: 24pt; font-weight: 700; letter-spacing: 0.8pt;
  margin: 0 0 4pt 0;
}
.subtitle {
  font-size: 11.5pt; font-weight: 600;
  margin: 0 0 5pt 0;
}
.address { font-size: 9.5pt; color: #333; margin: 0 0 4pt 0; }
.contact-line {
  display: flex; justify-content: space-between;
  margin: 8pt 0 10pt 0;
  font-size: 10pt; font-weight: 700;
}
.section-divider {
  border-top: 1pt solid #1a1a1a;
  border-bottom: 1pt solid #1a1a1a;
  padding: 4pt 0;
  margin: 14pt 0 6pt 0;
}
.section-title {
  text-align: center;
  font-weight: 700;
  font-size: 11pt;
  letter-spacing: 0.5pt;
  text-decoration: underline;
}
.profile-text {
  text-align: center;
  font-size: 10pt;
  line-height: 1.55;
  margin: 4pt 1em 8pt 1em;
}
.skill-cat { margin: 0 0 4pt 0; }
.skill-cat-label { font-weight: 700; }
.werdegang-entry { margin: 6pt 0 8pt 0; page-break-inside: avoid; }
.werdegang-head { display: flex; justify-content: space-between; align-items: baseline; }
.werdegang-title { font-weight: 700; font-size: 10.5pt; flex: 1; padding-right: 8pt; }
.werdegang-title .firma { font-style: normal; }
.werdegang-date { font-size: 9.5pt; color: #333; white-space: nowrap; }
ul.bullets { margin: 4pt 0 0 1.4em; padding: 0; }
ul.bullets li { margin-bottom: 2pt; }
.projektstelle { margin: 10pt 0 0 0; page-break-inside: avoid; }
.projektstelle-period { font-weight: 700; font-size: 10pt; margin: 4pt 0 1pt 0; }
.projektstelle-header { font-weight: 700; font-size: 10.5pt; margin: 0 0 4pt 0; }
.projektblock { margin: 6pt 0 8pt 0; page-break-inside: avoid; }
.projektblock-title { font-weight: 700; font-size: 10pt; margin: 0 0 2pt 0; }
.ergebnis { font-weight: 700; }
.bildung-entry {
  display: flex; justify-content: space-between; align-items: baseline;
  margin: 4pt 0;
}
.bildung-left { flex: 1; padding-right: 8pt; }
.bildung-institution { font-weight: 700; }
.bildung-abschluss { font-style: italic; font-size: 9.5pt; color: #333; }
.bildung-date { font-size: 9.5pt; color: #333; white-space: nowrap; }
.sprachen-row { display: flex; gap: 1.5em; flex-wrap: wrap; margin: 6pt 0; }
.sprachen-row > div { flex: 1; min-width: 8em; }
.zertifikate-list { margin: 4pt 0 0 0; padding: 0; list-style: none; }
.zertifikate-list li { font-weight: 700; margin: 3pt 0; }

/* === Page-break protection === */
/* Section dividers must never end up alone at the bottom of a page.
   `break-after: avoid` allein ist nur ein Hint, den WeasyPrint
   verwirft wenn der naechste Bruder ein `page-break-inside: avoid` hat
   und nicht in den Restplatz passt. Wir setzen daher BEIDES:
   - break-after auf den Divider
   - break-before auf das Element direkt danach
   Dadurch wird der Divider zwingend mit der ersten Folge-Section
   verschoben, anstatt orphaned am Seitenende zu landen. */
.section-divider {
  page-break-after: avoid;
  break-after: avoid;
}
.section-divider + * {
  page-break-before: avoid;
  break-before: avoid;
}
/* A heading must stay with at least the first line of its content */
.werdegang-title, .projektstelle-header, .projektblock-title, .projektstelle-period {
  page-break-after: avoid;
  break-after: avoid;
}
/* For each werdegang-entry / projektblock: keep header + first 2-3 bullets together
   (page-break-inside: avoid is already set above for these entries) */

/* For bullet lists: minimum lines on each page */
ul.bullets li { page-break-inside: avoid; }

/* Generic orphan/widow protection */
p, li {
  orphans: 2;
  widows: 2;
}

/* Bildung entries shouldn't split institution from abschluss */
.bildung-entry { page-break-inside: avoid; break-inside: avoid; }
</style>
</head>
<body>

<div class="header">
  <div class="name">{{ profile.person.name }}</div>
  <div class="subtitle">{{ zielposition_titel or "Projekt- und Prozessmanager" }}</div>
  {% if profile.person.adresse %}<div class="address">{{ profile.person.adresse }}</div>{% endif %}
</div>
<div class="contact-line">
  <span>{{ profile.person.phone or "" }}</span>
  <span>{{ profile.person.email or "" }}</span>
</div>

<div class="section-divider"><div class="section-title">PROFIL</div></div>
<p class="profile-text">{{ customized.berufsprofil_zugespitzt or profile.berufsprofil }}</p>

<div class="section-divider"><div class="section-title">SKILLS</div></div>
{% set sk = customized.skills_kategorisiert %}
{% if sk.prozessmanagement %}<div class="skill-cat"><span class="skill-cat-label">Prozessmanagement:</span> {{ sk.prozessmanagement | join(", ") }}</div>{% endif %}
{% if sk.projektmanagement %}<div class="skill-cat"><span class="skill-cat-label">Projektmanagement:</span> {{ sk.projektmanagement | join(", ") }}</div>{% endif %}
{% if sk.kommunikation_training %}<div class="skill-cat"><span class="skill-cat-label">Kommunikation &amp; Training:</span> {{ sk.kommunikation_training | join(", ") }}</div>{% endif %}
{% if sk.automatisierung_ki %}<div class="skill-cat"><span class="skill-cat-label">Automatisierung &amp; KI:</span> {{ sk.automatisierung_ki | join(", ") }}</div>{% endif %}
{% if sk.vertrieb %}<div class="skill-cat"><span class="skill-cat-label">Vertrieb:</span> {{ sk.vertrieb | join(", ") }}</div>{% endif %}

<div class="section-divider"><div class="section-title">WERDEGANG</div></div>
{% for job in customized.berufserfahrung %}
<div class="werdegang-entry">
  <div class="werdegang-head">
    <div class="werdegang-title">{{ job.position }}{% if job.firma %}, <span class="firma">{{ job.firma }}</span>{% endif %}</div>
    <div class="werdegang-date">{{ fmt_ym(job.von) }} - {% if job.bis %}{{ fmt_ym(job.bis) }}{% else %}heute{% endif %}</div>
  </div>
  {% if job.werdegang_bullets %}
  <ul class="bullets">
    {% for bullet in job.werdegang_bullets %}<li>{{ bullet }}</li>{% endfor %}
  </ul>
  {% endif %}
</div>
{% endfor %}

{# Detaillierte Projekterfahrung - nur Stellen mit projekterfahrung-Blöcken #}
{% set has_detail = customized.berufserfahrung | selectattr("projekterfahrung") | list | length > 0 %}
{% if has_detail %}
<div class="section-divider"><div class="section-title">DETAILLIERTE PROJEKTERFAHRUNG</div></div>
{% for job in customized.berufserfahrung %}
{% if job.projekterfahrung %}
<div class="projektstelle">
  <div class="projektstelle-period">[{{ fmt_year(job.von) }}{% if job.bis %} - {{ fmt_year(job.bis) }}{% else %} - heute{% endif %}]</div>
  <div class="projektstelle-header">{{ job.position }}{% if job.firma %} - {{ job.firma }}{% endif %}{% if job.standort %} ({{ job.standort }}){% endif %}</div>
  {% for block in job.projekterfahrung %}
  <div class="projektblock">
    <div class="projektblock-title">{{ block.titel }}</div>
    {% if block.aufgaben or block.ergebnisse %}
    <ul class="bullets">
      {% for a in block.aufgaben %}<li>{{ a }}</li>{% endfor %}
      {% for e in block.ergebnisse %}<li class="ergebnis">➔ Ergebnis: {{ e }}</li>{% endfor %}
    </ul>
    {% endif %}
  </div>
  {% endfor %}
</div>
{% endif %}
{% endfor %}
{% endif %}

<div class="section-divider"><div class="section-title">BILDUNG</div></div>
{% for edu in profile.ausbildung %}
<div class="bildung-entry">
  <div class="bildung-left">
    <div class="bildung-institution">{{ edu.institution }}</div>
    {% if edu.abschluss %}<div class="bildung-abschluss">{{ edu.abschluss }}</div>{% endif %}
  </div>
  <div class="bildung-date">{{ edu.jahr or "" }}</div>
</div>
{% endfor %}

{% if profile.sprachen %}
<div class="section-divider"><div class="section-title">SPRACHEN</div></div>
<div class="sprachen-row">
  {% for s in profile.sprachen %}<div>{{ s.sprache }} ............... {{ s.niveau }}</div>{% endfor %}
</div>
{% endif %}

{% if profile.zertifikate %}
<div class="section-divider"><div class="section-title">WEITERBILDUNGEN &amp; ZERTIFIKATE</div></div>
<ul class="zertifikate-list">
{% for z in profile.zertifikate %}<li>{{ z.name }}</li>{% endfor %}
</ul>
{% endif %}

</body>
</html>
