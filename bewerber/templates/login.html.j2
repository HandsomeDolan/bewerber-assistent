<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8">
<title>Login - Bewerber-Assistent</title>
{% include "_organic_ds.html.j2" %}
<style>
  body {
    display: flex; align-items: center; justify-content: center;
    min-height: 100vh; padding: var(--space-4);
  }
  .login-card { width: 380px; max-width: 92vw; padding: var(--space-8) var(--space-6); }
  .login-head {
    display: flex; flex-direction: column; align-items: center;
    gap: 12px; margin-bottom: var(--space-2);
  }
  .login-mark {
    width: 56px; height: 56px; border-radius: 50%;
    background: var(--color-accent); color: var(--color-bg);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-heading); font-size: 28px;
  }
  .name-row { display: flex; gap: var(--space-3); }
  .name-row .field { flex: 1; }
  .toggle { text-align: center; font-size: 13px; margin: var(--space-2) 0 0; }
  #error {
    display: none; margin: 0;
    background: var(--color-accent-100); color: var(--color-accent-800);
    border-radius: 999px; padding: 8px 16px; font-size: 13px; text-align: center;
  }
  #success {
    display: none; margin: 0;
    background: var(--color-accent-2-100); color: var(--color-accent-2-800);
    border-radius: 999px; padding: 8px 16px; font-size: 13px; text-align: center;
  }
  .hint { margin: var(--space-2) 0 0; font-size: 11.5px; text-align: center; line-height: 1.5; }
  .field { margin-bottom: var(--space-2); }
</style>
</head>
<body>
<div class="card elev-md login-card">
  <div class="login-head">
    <span class="login-mark">b</span>
    <h2 style="margin: 0; font-size: 26px;">Bewerber-Assistent</h2>
    <p class="text-muted" id="subtitle" style="margin: 0; font-size: 14px;">Bitte einloggen.</p>
  </div>

  <div id="login-form">
    <div class="field">
      <label>Username</label>
      <input class="input" type="text" id="login-username" autocomplete="username" autofocus required>
    </div>
    <div class="field">
      <label>Passwort</label>
      <input class="input" type="password" id="login-passwort" autocomplete="current-password" required>
    </div>
    <button class="btn btn-primary btn-block" id="login-btn" onclick="doLogin()">Einloggen</button>
    <p class="toggle">Noch kein Konto? <a href="#" onclick="showRegister(); return false;">Registrieren</a></p>
  </div>

  <div id="register-form" style="display:none;">
    <div class="name-row">
      <div class="field">
        <label>Vorname</label>
        <input class="input" type="text" id="reg-vorname" autocomplete="given-name" required>
      </div>
      <div class="field">
        <label>Nachname</label>
        <input class="input" type="text" id="reg-nachname" autocomplete="family-name" required>
      </div>
    </div>
    <div class="field">
      <label>Passwort (min. 8 Zeichen)</label>
      <input class="input" type="password" id="reg-passwort" autocomplete="new-password" required>
    </div>
    <div class="field">
      <label>Einladungs-Code</label>
      <input class="input" type="text" id="reg-invite" required>
    </div>
    <button class="btn btn-primary btn-block" id="reg-btn" onclick="doRegister()">Konto anlegen</button>
    <p class="toggle">Schon ein Konto? <a href="#" onclick="showLogin(); return false;">Einloggen</a></p>
  </div>

  <div id="error"></div>
  <div id="success"></div>
  <p class="hint text-muted">Login gilt 30 Tage (Cookie). Registrierung nur mit Einladungs-Code.</p>
</div>
<script>
function showError(msg) {
  const el = document.getElementById("error");
  el.textContent = msg; el.style.display = "block";
}
function showRegister() {
  document.getElementById("login-form").style.display = "none";
  document.getElementById("register-form").style.display = "block";
  document.getElementById("subtitle").textContent = "Neues Konto anlegen.";
  document.getElementById("error").style.display = "none";
}
function showLogin() {
  document.getElementById("register-form").style.display = "none";
  document.getElementById("login-form").style.display = "block";
  document.getElementById("subtitle").textContent = "Bitte einloggen.";
  document.getElementById("error").style.display = "none";
}
async function doLogin() {
  const username = document.getElementById("login-username").value.trim();
  const passwort = document.getElementById("login-passwort").value;
  if (!username || !passwort) { showError("Username und Passwort erforderlich."); return; }
  const btn = document.getElementById("login-btn");
  btn.disabled = true; btn.textContent = "...";
  try {
    const resp = await fetch("/login", {
      method: "POST", headers: {"Content-Type": "application/json"},
      body: JSON.stringify({username, passwort}),
    });
    const body = await resp.json();
    if (!resp.ok) { showError(body.error || "Login fehlgeschlagen"); btn.disabled = false; btn.textContent = "Einloggen"; return; }
    window.location.href = body.redirect || "/";
  } catch (e) { showError("Netzfehler: " + e.message); btn.disabled = false; btn.textContent = "Einloggen"; }
}
async function doRegister() {
  const vorname = document.getElementById("reg-vorname").value.trim();
  const nachname = document.getElementById("reg-nachname").value.trim();
  const passwort = document.getElementById("reg-passwort").value;
  const invite_code = document.getElementById("reg-invite").value.trim();
  if (!vorname || !nachname || !passwort || !invite_code) { showError("Bitte alle Felder ausfuellen."); return; }
  const btn = document.getElementById("reg-btn");
  btn.disabled = true; btn.textContent = "...";
  try {
    const resp = await fetch("/api/register", {
      method: "POST", headers: {"Content-Type": "application/json"},
      body: JSON.stringify({vorname, nachname, passwort, invite_code}),
    });
    const body = await resp.json();
    if (!resp.ok) { showError(body.error || "Registrierung fehlgeschlagen"); btn.disabled = false; btn.textContent = "Konto anlegen"; return; }
    const ok = document.getElementById("success");
    ok.textContent = "Konto angelegt. Dein Login-Name: " + body.username + " — weiterleiten ...";
    ok.style.display = "block";
    setTimeout(() => { window.location.href = body.redirect || "/"; }, 1500);
  } catch (e) { showError("Netzfehler: " + e.message); btn.disabled = false; btn.textContent = "Konto anlegen"; }
}
</script>
</body>
</html>
