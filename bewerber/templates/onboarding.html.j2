<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8">
<title>Onboarding - Bewerber-Assistent</title>
{% include "_organic_ds.html.j2" %}
<style>
  header {
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    border-bottom: 1px solid var(--color-divider); padding: var(--space-3) var(--space-4);
    display: flex; align-items: center; gap: var(--space-4);
  }
  header h1 { margin: 0; font-size: 22px; flex: 1; }
  header a { color: inherit; text-decoration: none; font-size: 13px; }
  header a:hover { color: var(--color-accent); }
  main { max-width: 760px; margin: var(--space-6) auto; padding: 0 var(--space-4); }
  .stepper { display: flex; gap: var(--space-2); margin-bottom: var(--space-4); font-size: 12px; }
  .stepper .step {
    padding: 7px 14px; background: var(--color-surface);
    border: 1px solid var(--color-divider); border-radius: 999px;
    flex: 1; text-align: center; color: color-mix(in srgb, var(--color-text) 65%, transparent);
  }
  .stepper .step.current { background: var(--color-accent); color: var(--color-bg); border-color: var(--color-accent); font-family: var(--font-heading); }
  .stepper .step.done { background: var(--color-accent-2-100); color: var(--color-accent-2-800); border-color: var(--color-accent-2-300); }
  section {
    background: var(--color-surface); border-radius: calc(var(--radius-lg) * 1.15);
    padding: var(--space-4) var(--space-6); margin-bottom: var(--space-3);
    box-shadow: var(--shadow-sm);
  }
  section h2 { margin: 0 0 6px 0; font-size: 22px; }
  section .hint { color: color-mix(in srgb, var(--color-text) 60%, transparent); font-size: 13px; margin: 0 0 var(--space-3) 0; line-height: 1.5; }
  label.field { display: block; margin: var(--space-3) 0; font-size: 13px; }
  label.field > span { display: block; font-weight: 600; margin-bottom: 4px; }
  label.field > small { display: block; color: color-mix(in srgb, var(--color-text) 55%, transparent); font-size: 11px; margin-bottom: 4px; font-weight: normal; }
  input[type="text"], input[type="number"], textarea {
    width: 100%; box-sizing: border-box; min-height: 36px;
    padding: 6px 14px; border: 1px solid var(--color-divider); border-radius: 999px;
    font: inherit; font-size: 13px; background: var(--color-bg);
    color: var(--color-text); caret-color: var(--color-accent);
  }
  input:focus-visible, textarea:focus-visible { border-color: var(--color-accent); outline-offset: 0; }
  textarea { font-family: ui-monospace, "SF Mono", Menlo, monospace; resize: vertical; min-height: 60px; border-radius: var(--radius-lg); }
  fieldset { border: 1px solid var(--color-divider); border-radius: var(--radius-md); padding: 8px 14px; margin: 10px 0; }
  fieldset legend { padding: 0 6px; font-weight: 600; font-size: 13px; }
  .row { display: flex; gap: var(--space-3); align-items: end; }
  .row > .field { flex: 1; }
  .checkbox-row { display: flex; gap: var(--space-4); }
  .checkbox-row label { font-size: 13px; cursor: pointer; }
  .checkbox-row input, .style-checkboxes input { accent-color: var(--color-accent); }

  .dropzone {
    display: block;
    border: 2px dashed color-mix(in srgb, var(--color-text) 25%, transparent);
    border-radius: var(--radius-lg);
    padding: 40px 20px; text-align: center;
    color: color-mix(in srgb, var(--color-text) 55%, transparent);
    cursor: pointer; transition: border-color 0.15s, background 0.15s;
  }
  .dropzone:hover, .dropzone.drag { border-color: var(--color-accent); background: var(--color-accent-100); color: var(--color-accent-700); }
  .dropzone input[type="file"] { display: none; }
  .file-list { margin: var(--space-3) 0 0 0; padding: 0; list-style: none; }
  .file-list li {
    padding: 6px 14px; border: 1px solid var(--color-divider); border-radius: 999px;
    margin-bottom: 6px; display: flex; justify-content: space-between; align-items: center;
    font-size: 13px; font-family: ui-monospace, "SF Mono", Menlo, monospace;
    background: var(--color-bg);
  }
  .file-list .remove { color: var(--color-accent-800); cursor: pointer; background: none; border: 0; font-size: 14px; }

  button.primary {
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    padding: 10px 20px; background: var(--color-accent); color: var(--color-bg);
    border: 1px solid transparent; border-radius: 999px;
    font-family: var(--font-heading); font-weight: var(--font-heading-weight);
    font-size: 13px; cursor: pointer;
  }
  button.primary:hover:not(:disabled) { background: var(--color-accent-600); }
  button.primary:disabled { opacity: 0.45; cursor: not-allowed; }
  button.secondary {
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    padding: 8px 16px; background: transparent; color: var(--color-text);
    border: 1px solid var(--color-divider); border-radius: 999px;
    font-family: var(--font-heading); font-weight: var(--font-heading-weight);
    font-size: 13px; cursor: pointer;
  }
  button.secondary:hover { background: color-mix(in srgb, var(--color-text) 7%, transparent); }
  .status-box { padding: 12px 18px; border-radius: var(--radius-md); margin-top: var(--space-3); font-size: 13px; display: none; }
  .status-box.info { display: block; background: var(--color-neutral-200); color: var(--color-neutral-800); }
  .status-box.ok { display: block; background: var(--color-accent-2-100); color: var(--color-accent-2-800); }
  .status-box.err { display: block; background: var(--color-accent-100); color: var(--color-accent-800); white-space: pre-wrap; }
  .summary-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 8px 18px; margin: 8px 0 14px 0; font-size: 13px;
  }
  .summary-grid .k { color: color-mix(in srgb, var(--color-text) 60%, transparent); }
  .summary-grid .v { font-weight: 700; }
  .style-checkboxes { display: flex; flex-direction: column; gap: 6px; }
  .style-checkboxes label { font-size: 13px; cursor: pointer; padding: 4px 10px; border-radius: 999px; }
  .style-checkboxes label:hover { background: color-mix(in srgb, var(--color-text) 6%, transparent); }
  .style-checkboxes .empty { color: color-mix(in srgb, var(--color-text) 50%, transparent); font-style: italic; font-size: 13px; }
  .finish-bar {
    background: var(--color-surface); border-radius: calc(var(--radius-lg) * 1.15);
    padding: var(--space-3) var(--space-4); display: flex; justify-content: space-between; align-items: center;
    margin-top: var(--space-3); box-shadow: var(--shadow-sm);
  }
  .finish-status { font-size: 13px; color: color-mix(in srgb, var(--color-text) 60%, transparent); }
  .scan-result {
    padding: 8px 14px; background: var(--color-bg); border: 1px solid var(--color-divider); border-radius: var(--radius-md);
    margin-top: 8px; font-size: 12px; font-family: ui-monospace, "SF Mono", Menlo, monospace;
    max-height: 160px; overflow-y: auto;
  }
</style>
</head>
<body>
<header>
  <h1>Onboarding{% if current_user %} - {{ current_user }}{% endif %}</h1>
  <a href="#" onclick="logout(event)">Logout</a>
</header>

<main>
  <div class="stepper">
    <div class="step current" id="step-1">1. Profil aus Dokumenten</div>
    <div class="step" id="step-2">2. Suchen + Locations</div>
    <div class="step" id="step-3">3. Anlagen-Ordner</div>
    <div class="step" id="step-4">4. Anschreiben-Stil</div>
  </div>

  <!-- ====================== STEP 1 ====================== -->
  <section>
    <h2>Step 1: Profil aus Dokumenten erstellen</h2>
    <p class="hint">
      Lade einen vorhandenen Lebenslauf + 1-3 Anschreiben (PDF oder DOCX) hoch.
      Die LLM extrahiert daraus dein Master-Profil. Dauert ~30-60 s.
      Du kannst waehrenddessen schon Step 2-4 ausfuellen.
    </p>
    <label class="dropzone" id="dropzone">
      <input type="file" id="file-input" accept=".pdf,.docx" multiple>
      <div id="dropzone-text">
        <b>Dateien hierhin ziehen</b> oder klicken zum Browsen<br>
        <small>PDF oder DOCX, mehrere Dateien moeglich</small>
      </div>
    </label>
    <ul class="file-list" id="file-list"></ul>
    <div style="margin-top: 16px;">
      <button id="extract-btn" class="primary" disabled onclick="startExtraction()">
        ▶ Profil extrahieren
      </button>
    </div>
    <div id="status-box" class="status-box"></div>
  </section>

  <!-- ====================== STEP 2 ====================== -->
  <section>
    <h2>Step 2: Suchen + Locations</h2>
    <p class="hint">
      Diese Werte landen in <code>searches.yaml</code>. Du kannst sie spaeter
      jederzeit ueber den ⚙ Suchen-Editor im Dashboard anpassen.
    </p>
    <label class="field">
      <span>Suchbegriffe</span>
      <small>Eine pro Zeile. Mind. 1 Pflicht. Beispiel: "KI Manager", "Lead Projektmanager".</small>
      <textarea id="onb-keywords" rows="4" oninput="updateFinishBtn()" placeholder="KI Manager&#10;Lead Projektmanager&#10;Senior Consultant Digitalisierung"></textarea>
    </label>
    <label class="field">
      <span>Locations</span>
      <small>Eine pro Zeile. Mind. 1 Pflicht.</small>
      <textarea id="onb-locations" rows="3" oninput="updateFinishBtn()" placeholder="Leipzig&#10;Berlin&#10;Remote"></textarea>
    </label>
    <label class="field">
      <span>Ausschluss-Keywords (optional)</span>
      <small>Eine pro Zeile. Wortgrenze, case-insensitive. Filtert vor Scoring.</small>
      <textarea id="onb-exclude" rows="2" placeholder="SPS&#10;PLS"></textarea>
    </label>
    <div class="row">
      <label class="field" style="flex:0 0 220px;">
        <span>Max. Tage seit Posting</span>
        <small>1-90</small>
        <input type="number" id="onb-max-days" min="1" max="90" value="14">
      </label>
      <fieldset class="field" style="flex:1;">
        <legend>Boards</legend>
        <div class="checkbox-row">
          <label><input type="checkbox" class="onb-board" value="arbeitsagentur" checked> Arbeitsagentur</label>
          <label><input type="checkbox" class="onb-board" value="linkedin"> LinkedIn</label>
          <label><input type="checkbox" class="onb-board" value="indeed"> Indeed</label>
        </div>
      </fieldset>
    </div>
  </section>

  <!-- ====================== STEP 3 ====================== -->
  <section>
    <h2>Step 3: Anlagen-Ordner (optional)</h2>
    <p class="hint">
      Lokaler Ordner mit Zeugnissen, Urkunden etc. Diese Dateien werden bei
      jedem Tailor-Lauf automatisch in den Bewerbungsordner kopiert.
      Pfade muessen absolut sein. Spaeter ueber 🗂 Anlagen verwalten editierbar.
    </p>
    <label class="field">
      <span>Pfad</span>
      <input type="text" id="onb-anlagen-path" placeholder="/Users/.../Bewerbungsunterlagen/_anlagen">
    </label>
    <button class="secondary" onclick="scanAnlagenFolder()">🔍 Pruefen</button>
    <div id="onb-anlagen-result" class="scan-result" style="display:none;"></div>
  </section>

  <!-- ====================== STEP 4 ====================== -->
  <section>
    <h2>Step 4: Anschreiben-Stil-Beispiele (optional)</h2>
    <p class="hint">
      Aus den in Step 1 hochgeladenen Dateien Anschreiben als Few-Shot-Beispiele
      auswaehlen. Die LLM nutzt sie, um deinen Schreibstil zu imitieren.
    </p>
    <div id="onb-style-checkboxes" class="style-checkboxes">
      <span class="empty">Erst in Step 1 Dateien hochladen, dann erscheinen hier die Checkboxen.</span>
    </div>
  </section>

  <!-- ====================== FINISH ====================== -->
  <div class="finish-bar">
    <div class="finish-status" id="finish-status">
      Bitte zuerst Step 1 (Extraktion) + Step 2 (Suchen) ausfuellen.
    </div>
    <button id="finish-btn" class="primary" disabled onclick="finishOnboarding()">
      Setup abschliessen → Dashboard
    </button>
  </div>
  <div id="finish-status-box" class="status-box" style="margin-top: 14px;"></div>
</main>

<script>
const SELECTED_FILES = [];
let extractionJobId = null;
let extractionDone = false;

const dropzone = document.getElementById("dropzone");
const fileInput = document.getElementById("file-input");
const fileList = document.getElementById("file-list");
const extractBtn = document.getElementById("extract-btn");
const finishBtn = document.getElementById("finish-btn");
const finishStatus = document.getElementById("finish-status");
const statusBox = document.getElementById("status-box");
const finishStatusBox = document.getElementById("finish-status-box");

function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
}
function linesToList(s) {
  return (s || "").split("\n").map(l => l.trim()).filter(Boolean);
}

function renderFileList() {
  fileList.innerHTML = "";
  SELECTED_FILES.forEach((f, i) => {
    const li = document.createElement("li");
    li.innerHTML = `<span>${escapeHtml(f.name)} <small style="color:#888;">(${Math.round(f.size / 1024)} KB)</small></span>
                    <button class="remove" onclick="removeFile(${i})" title="entfernen">✗</button>`;
    fileList.appendChild(li);
  });
  extractBtn.disabled = SELECTED_FILES.length === 0;
}
function removeFile(idx) { SELECTED_FILES.splice(idx, 1); renderFileList(); }
function addFiles(files) {
  for (const f of files) {
    if (!/\.(pdf|docx)$/i.test(f.name)) continue;
    if (!SELECTED_FILES.some(s => s.name === f.name && s.size === f.size)) SELECTED_FILES.push(f);
  }
  renderFileList();
}
fileInput.addEventListener("change", e => addFiles(e.target.files));
dropzone.addEventListener("dragover", e => { e.preventDefault(); dropzone.classList.add("drag"); });
dropzone.addEventListener("dragleave", () => dropzone.classList.remove("drag"));
dropzone.addEventListener("drop", e => {
  e.preventDefault(); dropzone.classList.remove("drag");
  addFiles(e.dataTransfer.files);
});

function setStatus(kind, msg) {
  statusBox.className = "status-box " + kind;
  statusBox.innerHTML = msg;
}

const PHASES = [
  "Dokumente lesen ...",
  "PDF-Texte extrahieren ...",
  "LLM analysiert (Werdegang) ...",
  "LLM analysiert (Skills + Ausbildung) ...",
  "Profil validieren ...",
];

async function startExtraction() {
  if (SELECTED_FILES.length === 0) return;
  extractBtn.disabled = true;
  fileInput.disabled = true;
  const fd = new FormData();
  for (const f of SELECTED_FILES) fd.append("files", f, f.name);
  try {
    const resp = await fetch("/api/onboarding/extract", {method: "POST", body: fd});
    const body = await resp.json();
    if (!resp.ok) throw new Error(body.error || "unbekannter Fehler");
    extractionJobId = body.job_id;
    populateStyleCheckboxes(body.files);
    setStatus("info", `<span id="phase-text">Extraktion gestartet ...</span>`);
    pollExtractionStatus();
  } catch (e) {
    setStatus("err", "Upload fehlgeschlagen: " + e.message);
    extractBtn.disabled = false;
    fileInput.disabled = false;
  }
}

function populateStyleCheckboxes(filenames) {
  // Step 4: alle hochgeladenen Files als Optionen anbieten. Defaults vorab-checked,
  // wenn der Filename "anschreiben" / "cover" enthaelt.
  const container = document.getElementById("onb-style-checkboxes");
  if (!filenames || filenames.length === 0) return;
  container.innerHTML = "";
  filenames.forEach(name => {
    const lower = name.toLowerCase();
    const looksLikeAnschreiben = /(anschreiben|coverletter|cover[\s_-]?letter|motivation)/i.test(lower);
    const label = document.createElement("label");
    label.innerHTML = `<input type="checkbox" class="onb-style-cb" value="${escapeHtml(name)}" ${looksLikeAnschreiben ? "checked" : ""}> ${escapeHtml(name)}`;
    container.appendChild(label);
  });
}

async function pollExtractionStatus() {
  if (!extractionJobId) return;
  let phaseIdx = 0;
  const phaseTimer = setInterval(() => {
    const el = document.getElementById("phase-text");
    if (el) {
      phaseIdx = Math.min(phaseIdx + 1, PHASES.length - 1);
      el.textContent = PHASES[phaseIdx];
    }
  }, 7000);
  const tick = async () => {
    try {
      const resp = await fetch("/api/onboarding/status?job_id=" + encodeURIComponent(extractionJobId));
      const data = await resp.json();
      if (data.status === "running") {
        setTimeout(tick, 1500);
        return;
      }
      clearInterval(phaseTimer);
      if (data.status === "done") {
        extractionDone = true;
        const s = data.summary || {};
        setStatus("ok",
          `<b>✓ Profil erstellt:</b>
          <div class="summary-grid">
            <div class="k">Name:</div>      <div class="v">${escapeHtml(s.name || "-")}</div>
            <div class="k">Berufsstellen:</div> <div class="v">${s.stellen || 0}</div>
            <div class="k">Ausbildungen:</div>  <div class="v">${s.ausbildung || 0}</div>
            <div class="k">Sprachen:</div>      <div class="v">${s.sprachen || 0}</div>
          </div>`,
        );
        document.getElementById("step-1").classList.remove("current");
        document.getElementById("step-1").classList.add("done");
        updateFinishBtn();
      } else if (data.status === "failed") {
        setStatus("err", "Extraktion fehlgeschlagen:\n" + (data.error || "unbekannt"));
        extractBtn.disabled = false;
        fileInput.disabled = false;
      }
    } catch (e) {
      clearInterval(phaseTimer);
      setStatus("err", "Status-Abfrage fehlgeschlagen: " + e.message);
    }
  };
  tick();
}

async function scanAnlagenFolder() {
  const path = document.getElementById("onb-anlagen-path").value.trim();
  const resultEl = document.getElementById("onb-anlagen-result");
  if (!path) { resultEl.style.display = "none"; return; }
  resultEl.style.display = "block";
  resultEl.textContent = "Pruefe ...";
  try {
    const resp = await fetch("/api/onboarding/scan-folder", {
      method: "POST", headers: {"Content-Type": "application/json"},
      body: JSON.stringify({path}),
    });
    const body = await resp.json();
    if (!resp.ok) {
      resultEl.textContent = "✗ " + (body.error || "Fehler");
      return;
    }
    if (body.files.length === 0) {
      resultEl.textContent = "Verzeichnis existiert, aber keine Dateien drin.";
      return;
    }
    resultEl.innerHTML = `✓ ${body.files.length} Dateien gefunden:\n` +
      body.files.map(f => `  ${escapeHtml(f.name)} (${f.size_kb} KB)`).join("\n");
  } catch (e) {
    resultEl.textContent = "Netzfehler: " + e.message;
  }
}

function updateFinishBtn() {
  const keywords = linesToList(document.getElementById("onb-keywords").value);
  const locations = linesToList(document.getElementById("onb-locations").value);
  const ready = extractionDone && keywords.length > 0 && locations.length > 0;
  finishBtn.disabled = !ready;
  if (!extractionDone) {
    finishStatus.textContent = "Warte auf Step 1 (Profil-Extraktion) ...";
  } else if (keywords.length === 0) {
    finishStatus.textContent = "Step 2: mindestens ein Suchbegriff erforderlich.";
  } else if (locations.length === 0) {
    finishStatus.textContent = "Step 2: mindestens eine Location erforderlich.";
  } else {
    finishStatus.textContent = "Alles bereit. Klick zum Speichern.";
  }
  // Step-2-Indikator updaten
  const step2 = document.getElementById("step-2");
  step2.classList.toggle("done", keywords.length > 0 && locations.length > 0);
}

async function finishOnboarding() {
  finishBtn.disabled = true;
  finishStatusBox.className = "status-box info";
  finishStatusBox.style.display = "block";
  finishStatusBox.textContent = "Speichere ...";
  try {
    const payload = {
      searches: {
        keywords: linesToList(document.getElementById("onb-keywords").value),
        boards: Array.from(document.querySelectorAll(".onb-board:checked")).map(cb => cb.value),
      },
      defaults: {
        locations: linesToList(document.getElementById("onb-locations").value),
        date_posted_max_days: parseInt(document.getElementById("onb-max-days").value, 10) || 14,
        exclude_keywords: linesToList(document.getElementById("onb-exclude").value),
      },
      anlagen_folder: document.getElementById("onb-anlagen-path").value.trim() || null,
      anschreiben_examples: Array.from(document.querySelectorAll(".onb-style-cb:checked")).map(cb => cb.value),
      extraction_job_id: extractionJobId,
    };
    const resp = await fetch("/api/onboarding/save", {
      method: "POST", headers: {"Content-Type": "application/json"},
      body: JSON.stringify(payload),
    });
    const data = await resp.json();
    if (!resp.ok) throw new Error(data.error || "Fehler beim Speichern");
    finishStatusBox.className = "status-box ok";
    const s = data.summary || {};
    finishStatusBox.innerHTML = `✓ Gespeichert: ${s.searches_keywords} Suchbegriffe, ${s.locations} Locations, ${s.anlagen || 0} Anlagen, ${s.anschreiben_examples || 0} Stil-Beispiele. Leite zum Dashboard weiter ...`;
    setTimeout(() => { window.location.href = data.redirect || "/"; }, 1200);
  } catch (e) {
    finishStatusBox.className = "status-box err";
    finishStatusBox.textContent = "✗ " + e.message;
    finishBtn.disabled = false;
  }
}

async function logout(evt) {
  if (evt) evt.preventDefault();
  try {
    const resp = await fetch("/logout", {method: "POST"});
    const body = await resp.json();
    window.location.href = body.redirect || "/login";
  } catch (e) { alert("Logout-Fehler: " + e.message); }
}

updateFinishBtn();
</script>
</body>
</html>
