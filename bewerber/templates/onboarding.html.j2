<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8">
<title>Onboarding - Bewerber-Assistent</title>
<style>
  body { font-family: "Helvetica Neue", Arial, sans-serif; margin: 0; padding: 0; background: #f7f8fa; color: #222; }
  header {
    background: #fff; border-bottom: 1px solid #ddd; padding: 12px 24px;
    display: flex; align-items: center; gap: 18px;
  }
  header h1 { margin: 0; font-size: 18px; flex: 1; }
  header a { color: #555; text-decoration: none; font-size: 13px; }
  header a:hover { color: #c33; }
  main { max-width: 760px; margin: 24px auto; padding: 0 16px; }
  .stepper { display: flex; gap: 6px; margin-bottom: 20px; font-size: 12px; color: #666; }
  .stepper .step { padding: 6px 12px; background: #fff; border: 1px solid #d8d8d8; border-radius: 14px; flex: 1; text-align: center; }
  .stepper .step.current { background: #2266cc; color: #fff; border-color: #2266cc; font-weight: 600; }
  .stepper .step.done { background: #e8f7ec; color: #1a5b2b; border-color: #b8e0c2; }
  .stepper .step.stub { opacity: 0.5; }
  section {
    background: #fff; border: 1px solid #e0e0e0; border-radius: 6px;
    padding: 22px 26px; margin-bottom: 18px;
  }
  section h2 { margin: 0 0 6px 0; font-size: 17px; }
  section .hint { color: #666; font-size: 13px; margin: 0 0 16px 0; line-height: 1.5; }
  .dropzone {
    border: 2px dashed #c0c8d0; border-radius: 6px;
    padding: 36px 20px; text-align: center; color: #888;
    cursor: pointer; transition: border-color 0.15s, background 0.15s;
  }
  .dropzone:hover, .dropzone.drag { border-color: #2266cc; background: #f0f6ff; color: #2266cc; }
  .dropzone input[type="file"] { display: none; }
  .file-list { margin: 14px 0 0 0; padding: 0; list-style: none; }
  .file-list li {
    padding: 6px 10px; border: 1px solid #e8e8e8; border-radius: 4px;
    margin-bottom: 6px; display: flex; justify-content: space-between; align-items: center;
    font-size: 13px; font-family: ui-monospace, "SF Mono", Menlo, monospace;
  }
  .file-list .remove { color: #c33; cursor: pointer; background: none; border: 0; font-size: 14px; }
  button.primary {
    padding: 9px 18px; background: #2266cc; color: #fff;
    border: 1px solid #2266cc; border-radius: 4px;
    font: inherit; font-weight: 600; cursor: pointer;
  }
  button.primary:hover:not(:disabled) { background: #1a55b3; }
  button.primary:disabled { opacity: 0.5; cursor: not-allowed; }
  button.secondary {
    padding: 9px 18px; background: #fff; color: #333;
    border: 1px solid #c0c8d0; border-radius: 4px;
    font: inherit; cursor: pointer;
  }
  .status-box { padding: 12px 14px; border-radius: 4px; margin-top: 14px; font-size: 13px; display: none; }
  .status-box.info { display: block; background: #e8f0fc; color: #1f4e8c; border: 1px solid #b8cee8; }
  .status-box.ok { display: block; background: #e8f7ec; color: #1a5b2b; border: 1px solid #b8e0c2; }
  .status-box.err { display: block; background: #fde9e9; color: #8a1a1a; border: 1px solid #f3b0b0; white-space: pre-wrap; }
  .summary-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 8px 18px; margin: 8px 0 14px 0; font-size: 13px;
  }
  .summary-grid .k { color: #666; }
  .summary-grid .v { font-weight: 700; }
  .stub-note { color: #888; font-style: italic; font-size: 13px; }
</style>
</head>
<body>
<header>
  <h1>Onboarding{% if current_user %} - {{ current_user }}{% endif %}</h1>
  <a href="#" onclick="logout(event)">Logout</a>
</header>

<main>
  <div class="stepper">
    <div class="step current" id="step-1">1. Profil aus Dokumenten</div>
    <div class="step stub">2. Suchen + Locations</div>
    <div class="step stub">3. Anlagen-Ordner</div>
    <div class="step stub">4. Anschreiben-Stil</div>
  </div>

  <section>
    <h2>Step 1: Profil aus Dokumenten erstellen</h2>
    <p class="hint">
      Lade einen vorhandenen Lebenslauf + 1-3 Anschreiben (PDF oder DOCX) hoch.
      Die LLM extrahiert daraus dein Master-Profil (Werdegang, Skills, Sprachen, Ausbildung).
      Dauert ~30-60 s. Du kannst waehrenddessen schon Schritt 2-4 ausfuellen
      (kommt in Phase 3).
    </p>

    <label class="dropzone" id="dropzone">
      <input type="file" id="file-input" accept=".pdf,.docx" multiple>
      <div id="dropzone-text">
        <b>Dateien hierhin ziehen</b> oder klicken zum Browsen<br>
        <small>PDF oder DOCX, mehrere Dateien moeglich</small>
      </div>
    </label>

    <ul class="file-list" id="file-list"></ul>

    <div style="margin-top: 16px;">
      <button id="extract-btn" class="primary" disabled onclick="startExtraction()">
        ▶ Profil extrahieren
      </button>
    </div>

    <div id="status-box" class="status-box"></div>
  </section>

  <section style="opacity: 0.6;">
    <h2>Step 2 - 4 (kommen in Phase 3)</h2>
    <p class="stub-note">Suchen + Locations, Anlagen-Ordner und Anschreiben-Stil werden hier eingefuegt.</p>
  </section>

  <div style="text-align: right;">
    <button id="finish-btn" class="primary" disabled onclick="finishToDashboard()">
      Zum Dashboard →
    </button>
  </div>
</main>

<script>
const SELECTED_FILES = [];
const dropzone = document.getElementById("dropzone");
const fileInput = document.getElementById("file-input");
const fileList = document.getElementById("file-list");
const extractBtn = document.getElementById("extract-btn");
const finishBtn = document.getElementById("finish-btn");
const statusBox = document.getElementById("status-box");
let currentJobId = null;
let pollTimer = null;

function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
}

function renderFileList() {
  fileList.innerHTML = "";
  SELECTED_FILES.forEach((f, i) => {
    const li = document.createElement("li");
    li.innerHTML = `<span>${escapeHtml(f.name)} <small style="color:#888;">(${Math.round(f.size / 1024)} KB)</small></span>
                    <button class="remove" onclick="removeFile(${i})" title="entfernen">✗</button>`;
    fileList.appendChild(li);
  });
  extractBtn.disabled = SELECTED_FILES.length === 0;
}

function removeFile(idx) {
  SELECTED_FILES.splice(idx, 1);
  renderFileList();
}

function addFiles(files) {
  for (const f of files) {
    if (!/\.(pdf|docx)$/i.test(f.name)) continue;
    if (!SELECTED_FILES.some(s => s.name === f.name && s.size === f.size)) {
      SELECTED_FILES.push(f);
    }
  }
  renderFileList();
}

fileInput.addEventListener("change", e => addFiles(e.target.files));
dropzone.addEventListener("dragover", e => { e.preventDefault(); dropzone.classList.add("drag"); });
dropzone.addEventListener("dragleave", () => dropzone.classList.remove("drag"));
dropzone.addEventListener("drop", e => {
  e.preventDefault();
  dropzone.classList.remove("drag");
  addFiles(e.dataTransfer.files);
});

function setStatus(kind, msg) {
  statusBox.className = "status-box " + kind;
  statusBox.innerHTML = msg;
}

const PHASES = [
  "Dokumente lesen ...",
  "PDF-Texte extrahieren ...",
  "LLM analysiert (Werdegang) ...",
  "LLM analysiert (Skills + Ausbildung) ...",
  "Profil validieren ...",
];

async function startExtraction() {
  if (SELECTED_FILES.length === 0) return;
  extractBtn.disabled = true;
  fileInput.disabled = true;

  const fd = new FormData();
  for (const f of SELECTED_FILES) fd.append("files", f, f.name);

  try {
    const resp = await fetch("/api/onboarding/extract", {method: "POST", body: fd});
    const body = await resp.json();
    if (!resp.ok) throw new Error(body.error || "unbekannter Fehler");
    currentJobId = body.job_id;
    setStatus("info", `<span id="phase-text">Extraktion gestartet ...</span>`);
    pollExtractionStatus();
  } catch (e) {
    setStatus("err", "Upload fehlgeschlagen: " + e.message);
    extractBtn.disabled = false;
    fileInput.disabled = false;
  }
}

async function pollExtractionStatus() {
  if (!currentJobId) return;
  let phaseIdx = 0;
  const phaseTimer = setInterval(() => {
    const el = document.getElementById("phase-text");
    if (el) {
      phaseIdx = Math.min(phaseIdx + 1, PHASES.length - 1);
      el.textContent = PHASES[phaseIdx];
    }
  }, 7000);

  const tick = async () => {
    try {
      const resp = await fetch("/api/onboarding/status?job_id=" + encodeURIComponent(currentJobId));
      const data = await resp.json();
      if (data.status === "running") {
        pollTimer = setTimeout(tick, 1500);
        return;
      }
      clearInterval(phaseTimer);
      if (data.status === "done") {
        const s = data.summary || {};
        setStatus("ok",
          `<b>✓ Profil erstellt:</b>
          <div class="summary-grid">
            <div class="k">Name:</div>      <div class="v">${escapeHtml(s.name || "-")}</div>
            <div class="k">Berufsstellen:</div> <div class="v">${s.stellen || 0}</div>
            <div class="k">Ausbildungen:</div>  <div class="v">${s.ausbildung || 0}</div>
            <div class="k">Sprachen:</div>      <div class="v">${s.sprachen || 0}</div>
          </div>
          <div style="font-size:12px; color:#666;">Gespeichert: <code>${escapeHtml(data.master_profile_path || "")}</code></div>`,
        );
        document.getElementById("step-1").classList.remove("current");
        document.getElementById("step-1").classList.add("done");
        finishBtn.disabled = false;
      } else if (data.status === "failed") {
        setStatus("err", "Extraktion fehlgeschlagen:\n" + (data.error || "unbekannt"));
        extractBtn.disabled = false;
        fileInput.disabled = false;
      } else {
        setStatus("err", "Unerwarteter Status: " + JSON.stringify(data));
      }
    } catch (e) {
      clearInterval(phaseTimer);
      setStatus("err", "Status-Abfrage fehlgeschlagen: " + e.message);
    }
  };
  tick();
}

function finishToDashboard() {
  window.location.href = "/";
}

async function logout(evt) {
  if (evt) evt.preventDefault();
  try {
    const resp = await fetch("/logout", {method: "POST"});
    const body = await resp.json();
    window.location.href = body.redirect || "/login";
  } catch (e) { alert("Logout-Fehler: " + e.message); }
}
</script>
</body>
</html>
