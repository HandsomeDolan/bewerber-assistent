async function startDiscoverRun() {
  if (!IS_HTTP) {
    alert("Discover-Run geht nur ueber 'bewerber serve' (HTTP).");
    return;
  }
  const btn = document.getElementById("discover-run-btn");
  const statusEl = document.getElementById("discover-run-status");
  btn.disabled = true;
  btn.textContent = "⏳ laeuft ...";
  statusEl.textContent = "Discover gestartet ...";
  try {
    const resp = await fetch("/api/discover/run", {method: "POST"});
    const body = await resp.json();
    if (!resp.ok) {
      if (resp.status === 409 && body.current_job_id) {
        statusEl.textContent = "Ein Discover-Run laeuft bereits - warte auf Abschluss ...";
        pollDiscoverStatus(body.current_job_id);
        return;
      }
      throw new Error(body.error || "Fehler");
    }
    pollDiscoverStatus(body.job_id);
  } catch (e) {
    statusEl.style.color = "#c33";
    statusEl.textContent = "✗ " + e.message;
    btn.disabled = false;
    btn.textContent = "▶ Discover jetzt starten";
  }
}

async function pollDiscoverStatus(jobId) {
  const btn = document.getElementById("discover-run-btn");
  const statusEl = document.getElementById("discover-run-status");
  const tick = async () => {
    try {
      const resp = await fetch("/api/discover/status?job_id=" + encodeURIComponent(jobId));
      const data = await resp.json();
      if (data.status === "running") {
        statusEl.textContent = `⏳ laeuft (seit ${data.started_at || "?"})`;
        setTimeout(tick, 3000);
        return;
      }
      if (data.status === "done") {
        statusEl.style.color = "#1a5b2b";
        statusEl.textContent = `✓ fertig: ${data.new_jobs} neu, ${data.total_jobs} gesamt. Dashboard wird neu geladen ...`;
        setTimeout(() => window.location.reload(), 1500);
        return;
      }
      if (data.status === "failed") {
        statusEl.style.color = "#c33";
        statusEl.textContent = "✗ " + (data.error || "Fehler");
        btn.disabled = false;
        btn.textContent = "▶ Discover jetzt starten";
        return;
      }
    } catch (e) {
      statusEl.style.color = "#c33";
      statusEl.textContent = "Polling-Fehler: " + e.message;
      btn.disabled = false;
      btn.textContent = "▶ Discover jetzt starten";
    }
  };
  tick();
}

