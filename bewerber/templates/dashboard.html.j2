async function startBatchTailor() {
  const start = document.getElementById("batch-tailor-start").value.trim();
  if (!start) { alert("Starttermin ist erforderlich."); return; }
  const gehalt = document.getElementById("batch-tailor-gehalt").value.trim() || null;
  const sprache = document.getElementById("batch-tailor-sprache").value || "de";
  const template_set = document.getElementById("batch-tailor-set").value || "classic";
  const jobIds = Array.from(SELECTED);
  closeBatchTailorParamsModal();

  // Progress-Modal aufbauen
  const modal = document.getElementById("batch-tailor-progress-modal");
  const rowsEl = document.getElementById("batch-tailor-rows");
  const summary = document.getElementById("batch-tailor-summary");
  const closeBtn = document.getElementById("batch-tailor-close");
  rowsEl.innerHTML = "";
  summary.textContent = `0/${jobIds.length} fertig`;
  closeBtn.disabled = true;
  jobIds.forEach((jid, i) => {
    const job = STATE.jobs[jid];
    const label = job ? `${job.raw.title} - ${job.raw.company}` : `Job ${i+1}`;
    const row = document.createElement("div");
    row.className = "batch-row";
    row.dataset.index = String(i);
    row.innerHTML = `
      <span class="icon">⏳</span>
      <span class="label">${escapeHtml(label)}</span>
      <div class="bar-wrap"><div class="bar"></div></div>
    `;
    rowsEl.appendChild(row);
  });
  modal.style.display = "block";

  const resp = await fetch("/api/batch-tailor", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({job_ids: jobIds, starttermin: start, gehalt, sprache, template_set}),
  });
  if (!resp.ok) {
    const body = await resp.json().catch(() => ({}));
    alert("Batch-Tailor konnte nicht gestartet werden: " + (body.error || resp.status));
    modal.style.display = "none";
    return;
  }
  const reader = resp.body.getReader();
  const decoder = new TextDecoder();
  let buffer = "";
  let done = 0, errors = 0, skipped = 0;
  while (true) {
    const {value, done: streamDone} = await reader.read();
    if (streamDone) break;
    buffer += decoder.decode(value, {stream: true});
    const lines = buffer.split("\n");
    buffer = lines.pop() || "";
    for (const ln of lines) {
      const t = ln.trim();
      if (!t) continue;
      let ev;
      try { ev = JSON.parse(t); } catch (e) { continue; }
      handleBatchTailorEvent(ev);
      if (ev.event === "done") done++;
      if (ev.event === "error") errors++;
      if (ev.event === "skipped_already_tailored") skipped++;
      summary.textContent = `${done + errors + skipped}/${jobIds.length} verarbeitet (${done} neu, ${skipped} bereits getailored, ${errors} Fehler)`;
    }
  }
  closeBtn.disabled = false;
}

function handleBatchTailorEvent(ev) {
  const rowsEl = document.getElementById("batch-tailor-rows");
  const row = rowsEl.querySelector(`.batch-row[data-index="${ev.index}"]`);
  if (!row && ev.event !== "begin" && ev.event !== "complete") return;
  const bar = row && row.querySelector(".bar");
  const icon = row && row.querySelector(".icon");
  const label = row && row.querySelector(".label");

  switch (ev.event) {
    case "begin":
    case "complete":
      return;
    case "start":
      if (bar) bar.style.width = "5%";
      break;
    case "label":
      if (label) label.textContent = ev.label;
      if (bar) bar.style.width = "20%";
      break;
    case "done":
      row.classList.add("done");
      if (icon) icon.textContent = "✓";
      break;
    case "skipped_already_tailored":
      row.classList.add("done");
      if (icon) icon.textContent = "⊘";
      if (label) label.innerHTML = `<span class="muted">${escapeHtml(ev.label)} (bereits getailored)</span>`;
      break;
    case "error":
      row.classList.add("error");
      if (icon) icon.textContent = "✗";
      if (label) label.innerHTML = `${escapeHtml(label.textContent)}<div class="err-msg">${escapeHtml(ev.error)}</div>`;
      break;
  }
}

function closeBatchTailorProgressModal() {
  document.getElementById("batch-tailor-progress-modal").style.display = "none";
  window.location.reload();
}

// ---------------------------------------------------------------------------
// Batch-Add: streamt NDJSON-Events vom Server pro URL
// ---------------------------------------------------------------------------

async function startBatch() {
  if (!IS_HTTP) {
    alert("Batch-Lauf funktioniert nur ueber 'bewerber serve' (HTTP).");
    return;
  }
  const text = (document.getElementById("batch-urls").value || "").trim();
  const urls = text.split("\n").map(s => s.trim()).filter(Boolean);
  if (urls.length === 0) {
    alert("Bitte mindestens eine URL eingeben (pro Zeile).");
    return;
  }
  // Modal aufbauen
  const modal = document.getElementById("batch-modal");
  const rowsEl = document.getElementById("batch-rows");
  const summary = document.getElementById("batch-summary");
  const closeBtn = document.getElementById("batch-close");
  rowsEl.innerHTML = "";
  summary.textContent = `0/${urls.length} fertig`;
  closeBtn.disabled = true;
  urls.forEach((_, i) => {
    const row = document.createElement("div");
    row.className = "batch-row";
    row.dataset.index = String(i);
    row.innerHTML = `
      <span class="icon">⏳</span>
      <span class="label">Job ${i + 1}</span>
      <div class="bar-wrap"><div class="bar"></div></div>
    `;
    rowsEl.appendChild(row);
  });
  modal.style.display = "block";

  // POST + NDJSON-Stream parsen
  let done = 0, errors = 0, dupes = 0;
  const resp = await fetch("/api/batch-add-postings", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({urls}),
  });
  if (!resp.ok) {
    const body = await resp.json().catch(() => ({}));
    alert("Batch konnte nicht gestartet werden: " + (body.error || resp.status));
    modal.style.display = "none";
    return;
  }
  const reader = resp.body.getReader();
  const decoder = new TextDecoder();
  let buffer = "";
  while (true) {
    const {value, done: streamDone} = await reader.read();
    if (streamDone) break;
    buffer += decoder.decode(value, {stream: true});
    const lines = buffer.split("\n");
    buffer = lines.pop() || "";  // letzte (evtl. unvollstaendige) Zeile zurueckhalten
    for (const line of lines) {
      const trimmed = line.trim();
      if (!trimmed) continue;
      let ev;
      try { ev = JSON.parse(trimmed); } catch (e) { continue; }
      handleBatchEvent(ev);
      if (ev.event === "done") done++;
      if (ev.event === "error") errors++;
      if (ev.event === "skipped_duplicate") dupes++;
      summary.textContent = `${done + errors + dupes}/${urls.length} verarbeitet (${done} neu, ${dupes} Duplikate, ${errors} Fehler)`;
    }
  }
  closeBtn.disabled = false;
}

function handleBatchEvent(ev) {
  const rowsEl = document.getElementById("batch-rows");
  const row = rowsEl.querySelector(`.batch-row[data-index="${ev.index}"]`);
  if (!row && ev.event !== "begin" && ev.event !== "complete") return;
  const bar = row && row.querySelector(".bar");
  const icon = row && row.querySelector(".icon");
  const label = row && row.querySelector(".label");

  switch (ev.event) {
    case "begin":
    case "complete":
      return;
    case "start":
      if (bar) bar.style.width = "10%";
      break;
    case "phase":
      if (bar) bar.style.width = ev.phase === "snapshot" ? "35%" : "70%";
      break;
    case "extracted":
      // Hier wechselt das "Job N" Label zum echten Rollennamen
      if (label) label.textContent = `${ev.rolle} - ${ev.firma}`;
      if (bar) bar.style.width = "80%";
      break;
    case "done":
      row.classList.add("done");
      if (icon) icon.textContent = "✓";
      break;
    case "error":
      row.classList.add("error");
      if (icon) icon.textContent = "✗";
      if (label) label.innerHTML = `<span title="${escapeAttr(ev.url)}">${escapeHtml(ev.url)}</span><div class="err-msg">${escapeHtml(ev.error)}</div>`;
      break;
    case "skipped_duplicate":
      row.classList.add("done");
      if (icon) icon.textContent = "⊘";
      if (label) label.innerHTML = `<span class="muted">${escapeHtml(ev.url)} (bereits erfasst)</span>`;
      break;
  }
}

function closeBatchModal() {
  document.getElementById("batch-modal").style.display = "none";
  // Dashboard neu laden, damit die neuen Jobs erscheinen + failed_urls
  window.location.reload();
}

async function retryFailed(url, btn) {
  if (!IS_HTTP) return;
  btn.disabled = true;
  btn.textContent = "läuft ...";
  // Single-URL-Batch starten ueber dieselbe Streaming-API
  try {
    const resp = await fetch("/api/batch-add-postings", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify({urls: [url]}),
    });
    if (!resp.ok) {
      btn.textContent = "↻ Erneut";
      btn.disabled = false;
      alert("Retry fehlgeschlagen: " + resp.status);
      return;
    }
    // Stream lesen aber nicht visualisieren - am Ende reloaden
    const reader = resp.body.getReader();
    const decoder = new TextDecoder();
    let lastEvent = null;
    let buffer = "";
    while (true) {
      const {value, done} = await reader.read();
      if (done) break;
      buffer += decoder.decode(value, {stream: true});
      const lines = buffer.split("\n");
      buffer = lines.pop() || "";
      for (const ln of lines) {
        const t = ln.trim();
        if (!t) continue;
        try { lastEvent = JSON.parse(t); } catch (e) {}
      }
    }
    window.location.reload();
  } catch (e) {
    btn.textContent = "↻ Erneut";
    btn.disabled = false;
    alert("Retry-Fehler: " + e.message);
  }
}

async function removeFailed(url, btn) {
  if (!IS_HTTP) return;
  btn.disabled = true;
  try {
    const resp = await fetch("/api/failed-urls/remove", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify({url}),
    });
    if (!resp.ok) throw new Error("Status " + resp.status);
    btn.closest(".failed-url-row").remove();
  } catch (e) {
    btn.disabled = false;
    alert("Konnte nicht entfernen: " + e.message);
  }
}

async function clearAllFailed() {
  if (!IS_HTTP) return;
  if (!confirm("Alle fehlgeschlagenen URLs aus der Liste entfernen?")) return;
  try {
    const resp = await fetch("/api/failed-urls/clear", {method: "POST"});
    if (!resp.ok) throw new Error("Status " + resp.status);
    window.location.reload();
  } catch (e) {
    alert("Fehler: " + e.message);
  }
}

async function addPostingFromUrl() {
  const urlEl = document.getElementById("add-url");
  const firmaEl = document.getElementById("add-firma");
  const rolleEl = document.getElementById("add-rolle");
  const btn = document.getElementById("add-btn");
  const statusEl = document.getElementById("add-status");
  const url = urlEl.value.trim();
  const firma = firmaEl.value.trim();
  const rolle = rolleEl.value.trim();
  if (!url || !firma || !rolle) {
    statusEl.style.color = "#c33";
    statusEl.textContent = "URL, Firma und Rolle sind erforderlich.";
    statusEl.style.display = "block";
    return;
  }
  if (!IS_HTTP) {
    alert("Manuelles Hinzufuegen funktioniert nur via 'bewerber serve' (HTTP).");
    return;
  }
  btn.disabled = true;
  btn.textContent = "⏳ scrapt + scort ...";
  statusEl.style.color = "#444";
  statusEl.textContent = "Snapshot + Scoring laufen ... ca. 10-15s";
  statusEl.style.display = "block";

  try {
    const resp = await fetch("/api/add-posting", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify({url, firma, rolle}),
    });
    const data = await resp.json();
    if (!resp.ok) throw new Error(data.error || "unbekannter Fehler");
    statusEl.style.color = "#1a5b2b";
    statusEl.textContent = `✓ Hinzugefuegt (Fit-Score ${data.fit_score}). Dashboard wird neu geladen ...`;
    setTimeout(() => window.location.reload(), 1200);
  } catch (e) {
    statusEl.style.color = "#c33";
    statusEl.textContent = "✗ " + e.message;
    btn.disabled = false;
    btn.textContent = "+ Ausschreibung hinzufuegen";
  }
}

document.querySelectorAll("th[data-sort]").forEach(th => {
  th.addEventListener("click", () => {
    const k = th.dataset.sort;
    currentSort = { key: k, dir: currentSort.key === k ? -currentSort.dir : (k === "score" ? -1 : 1) };
    applyFilters();
  });
});
[q, fStatus, fScore, fBoard].forEach(el => el.addEventListener("input", applyFilters));
// Erst Sets laden, dann rendern: vermeidet leere Design-Dropdowns beim ersten Paint
// und den doppelten applyFilters-Lauf. loadTemplateSets faengt Fehler intern ab.
loadTemplateSets().then(() => { fillDefaultSet(); setView(currentView); });
loadMyThemes();
</script>
