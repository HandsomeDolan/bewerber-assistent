const WORKSPACE = {{ workspace_path | tojson }};
const IS_HTTP = window.location.protocol.startsWith("http");

async function apiCall(path, body) {
  if (!IS_HTTP) {
    alert("Diese Aktion braucht den HTTP-Server. Starte den Server mit:\n\n  bewerber serve\n\nund öffne dann http://127.0.0.1:<port>/");
    throw new Error("Static mode (kein HTTP-Server) - API nicht verfuegbar");
  }
  const resp = await fetch(path, {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify(body),
  });
  if (!resp.ok) {
    const err = await resp.json().catch(() => ({error: resp.statusText}));
    throw new Error(err.error || "API call failed");
  }
  return resp.json();
}

