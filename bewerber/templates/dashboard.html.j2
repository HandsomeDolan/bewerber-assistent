  const short = safe.slice(0, DESC_PREVIEW_CHARS);
  return (
    `<span class="desc-short">${short}…</span>` +
    `<span class="desc-full" style="display:none;">${safe}</span>` +
    ` <button class="desc-toggle" onclick="toggleDesc('${jid}', event)">Mehr lesen</button>`
  );
}
