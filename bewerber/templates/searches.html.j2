<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8">
<title>Suchkonfiguration - Bewerber</title>
{% include "_organic_ds.html.j2" %}
<style>
  header {
    position: sticky; top: 0; z-index: 10;
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--color-divider);
    padding: var(--space-3) var(--space-4);
    display: flex; align-items: center; gap: var(--space-4);
  }
  header h1 { margin: 0; font-size: 22px; flex: 1; }
  header a.back { color: inherit; text-decoration: none; font-size: 14px; }
  header a.back:hover { color: var(--color-accent); }
  .toolbar { display: flex; gap: var(--space-2); }
  main { max-width: 980px; margin: var(--space-6) auto; padding: 0 var(--space-4); }
  section.card { margin-bottom: var(--space-4); }
  section.card > h2 { font-size: 24px; margin: 0 0 var(--space-2); display: flex; justify-content: space-between; align-items: center; gap: var(--space-2); }
  label.field { display: block; margin: var(--space-3) 0; font-size: 13px; }
  label.field > span { display: block; margin-bottom: 4px; font-weight: 600; }
  label.field > small { display: block; font-weight: normal; color: color-mix(in srgb, var(--color-text) 55%, transparent); font-size: 11px; margin-bottom: 4px; }
  textarea.input { font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 13px; border-radius: var(--radius-lg); min-height: 60px; }
  input.invalid, textarea.invalid { border-color: var(--color-accent-800); background: var(--color-accent-100); }
  .row { display: flex; gap: var(--space-3); align-items: flex-start; }
  .row > label.field { flex: 1; }
  .search-card {
    border: 1px solid var(--color-divider); border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4); margin: var(--space-3) 0;
    background: color-mix(in srgb, var(--color-surface) 55%, transparent);
  }
  /* Dezente Hervorhebung fuer frisch hinzugefuegte Cards; blendet weich aus */
  .search-card--new { animation: card-new-fade 2.5s ease-out; }
  @keyframes card-new-fade {
    0%   { background: var(--color-accent-100); border-color: var(--color-accent); box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 18%, transparent); }
    60%  { background: var(--color-accent-100); border-color: var(--color-accent); box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 12%, transparent); }
    100% { background: color-mix(in srgb, var(--color-surface) 55%, transparent); border-color: var(--color-divider); box-shadow: none; }
  }
  .search-card .head { display: flex; gap: var(--space-2); align-items: center; margin-bottom: var(--space-2); }
  .search-card .head input.name { flex: 1; font-weight: 600; font-size: 14px; }
  .search-card fieldset { border: 1px solid var(--color-divider); border-radius: var(--radius-md); padding: 8px 14px; flex: 1; }
  .search-card legend { font-weight: 600; padding: 0 6px; font-size: 13px; }
  .boards { display: flex; gap: var(--space-3); margin-top: 4px; }
  .boards label { font-size: 13px; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; }
  .boards input[type="checkbox"] { accent-color: var(--color-accent); width: 15px; height: 15px; }
  .empty-state { padding: var(--space-6); text-align: center; color: color-mix(in srgb, var(--color-text) 50%, transparent); font-style: italic; }
  #status { padding: 10px 18px; border-radius: var(--radius-md); margin-bottom: var(--space-3); display: none; }
  #status.ok { display: block; background: var(--color-accent-2-100); color: var(--color-accent-2-800); }
  #status.error { display: block; background: var(--color-accent-100); color: var(--color-accent-800); white-space: pre-wrap; }
  .dirty-flag { color: var(--color-accent-600); font-size: 12px; font-family: var(--font-body); }
  .modal-overlay { position: fixed; inset: 0; display: grid; place-items: center; padding: var(--space-4); background: color-mix(in srgb, var(--color-neutral-900) 50%, transparent); z-index: 100; }
  .modal { width: min(560px, 100%); display: flex; flex-direction: column; padding: var(--space-4); border-radius: var(--radius-lg); background: var(--color-surface); box-shadow: var(--shadow-lg); }
  .modal h3 { font-size: 22px; }
  .kw-group-title { font-weight: 600; font-size: 11px; color: var(--color-accent); margin: 10px 0 4px; text-transform: uppercase; letter-spacing: 0.08em; font-family: var(--font-body); }
  .kw-item { display: block; font-size: 13px; padding: 2px 0; }
  .kw-item input[type="checkbox"], #kw-mode-generate, #kw-mode-manual { accent-color: var(--color-accent); }
</style>
</head>
<body>
<header>
  <a class="back" href="/">← Dashboard</a>
  <h1>Suchkonfiguration <span id="dirty" class="dirty-flag" style="display:none;"> (ungespeicherte Aenderungen)</span></h1>
  <div class="toolbar">
    <button class="btn btn-secondary" id="reload-btn" title="Aenderungen verwerfen">↺ Neu laden</button>
    <button class="btn btn-primary" id="save-btn" disabled>Speichern</button>
  </div>
</header>

<main>
  <div id="status"></div>

  <section class="card elev-sm" id="defaults-section">
    <h2>Globale Einstellungen</h2>
    <div class="row">
      <label class="field">
        <span>Standorte</span>
        <small>Eine pro Zeile. Wird auf jede Suche angewendet.</small>
        <textarea class="input" data-path="defaults.locations" rows="3" placeholder="Leipzig&#10;Berlin&#10;Remote"></textarea>
      </label>
      <label class="field" style="flex:0 0 200px;">
        <span>Max. Tage seit Posting</span>
        <small>1-90</small>
        <input class="input" type="number" data-path="defaults.date_posted_max_days" min="1" max="90" value="14">
      </label>
    </div>
    <label class="field">
      <span>Globale Ausschluss-Keywords</span>
      <small>Eine pro Zeile. Wortgrenze, case-insensitive. Matched gegen Titel + Firma. "PLS" filtert "PLS Engineer", aber NICHT "PLSQL Developer".</small>
      <textarea class="input" data-path="defaults.exclude_keywords" rows="3" placeholder="SPS&#10;PLS"></textarea>
    </label>
  </section>

  <section class="card elev-sm" id="searches-section">
    <h2>
      Suchen
      <button class="btn btn-secondary" id="add-btn">+ Suche hinzufuegen</button>
    </h2>
    <div id="searches-list">
      <div class="empty-state">Noch keine Suchen konfiguriert. Klick auf "Suche hinzufuegen".</div>
    </div>
  </section>
</main>

<template id="search-card-template">
  <div class="search-card">
    <div class="head">
      <input type="text" class="input name" placeholder="Name der Suche (z.B. KI Manager)" required>
      <button class="btn btn-secondary gen-kw-btn" type="button" title="Keywords hinzufügen" style="font-size:12px;">✨ Keywords</button>
      <button class="btn btn-icon btn-secondary dup-btn" type="button" title="Duplizieren">⧉</button>
      <button class="btn btn-icon btn-secondary del-btn" type="button" title="Loeschen" style="color: var(--color-accent-800);">✕</button>
    </div>
    <label class="field">
      <span>Suchbegriffe</span>
      <small>Eine pro Zeile. Werden bei den Job-Boards als Suchanfrage verwendet.</small>
      <textarea class="input keywords" rows="4" placeholder="KI Manager&#10;AI Product Manager"></textarea>
    </label>
    <div class="row">
      <fieldset class="field">
        <legend>Boards</legend>
        <div class="boards">
          <label><input type="checkbox" class="board" value="arbeitsagentur"> Arbeitsagentur</label>
          <label><input type="checkbox" class="board" value="linkedin"> LinkedIn</label>
          <label><input type="checkbox" class="board" value="indeed"> Indeed</label>
        </div>
      </fieldset>
    </div>
    <label class="field">
      <span>Ausschluss-Keywords (zusaetzlich zu den globalen)</span>
      <small>Eine pro Zeile. Nur fuer DIESE Suche.</small>
      <textarea class="input exclude" rows="2" placeholder="Vertrieb"></textarea>
    </label>
  </div>
</template>

<div id="kw-modal" class="modal-overlay" style="display:none;">
  <div class="modal">
    <h3 style="margin-top:0;">Keywords hinzufügen</h3>
    <div id="kw-linkedin-hint" style="display:none; font-size:12px; color:var(--color-accent-700); margin-bottom:10px;">
      ⚠ Board LinkedIn aktiv: jede Variante = eine zusätzliche LinkedIn-Abfrage.
    </div>

    <label style="display:block; margin-bottom:6px;">
      <input type="checkbox" id="kw-mode-generate" checked> Varianten generieren
    </label>
    <textarea class="input" id="kw-desc" rows="2" placeholder="Kurz beschreiben, was du suchst (optional): z.B. strategische Rollen im Mittelstand, kein reines Consulting"></textarea>

    <label style="display:block; margin:12px 0 6px;">
      <input type="checkbox" id="kw-mode-manual"> Ich füge Keywords selbst hinzu
    </label>
    <textarea class="input" id="kw-manual" rows="3" placeholder="ein Keyword pro Zeile …" style="display:none;"></textarea>

    <div id="kw-status" style="font-size:13px; margin:10px 0; min-height:18px;"></div>
    <div id="kw-suggestions" style="max-height:260px; overflow:auto; margin-bottom:12px;"></div>

    <div style="display:flex; justify-content:flex-end; gap:8px;">
      <button class="btn btn-secondary" type="button" id="kw-cancel">Abbrechen</button>
      <button class="btn btn-primary" type="button" id="kw-generate">Generieren</button>
      <button class="btn btn-primary" type="button" id="kw-apply" style="display:none;">Übernehmen</button>
    </div>
  </div>
</div>

<script id="initial-config" type="application/json">{{ config_json }}</script>
<script>
const VALID_BOARDS = ["arbeitsagentur", "linkedin", "indeed"];
let initialConfig = JSON.parse(document.getElementById("initial-config").textContent);
let dirty = false;

function linesToList(s) {
  return (s || "").split("\n").map(l => l.trim()).filter(Boolean);
}
function listToLines(arr) {
  return Array.isArray(arr) ? arr.join("\n") : "";
}
function setDirty(v) {
  dirty = v;
  document.getElementById("dirty").style.display = v ? "" : "none";
  document.getElementById("save-btn").disabled = !v;
}
function setStatus(kind, msg) {
  const el = document.getElementById("status");
  el.className = kind;
  el.textContent = msg;
  if (!msg) el.style.display = "none";
}

function renderConfig(cfg) {
  // Defaults
  document.querySelector('[data-path="defaults.locations"]').value =
    listToLines(cfg.defaults && cfg.defaults.locations);
  document.querySelector('[data-path="defaults.date_posted_max_days"]').value =
    (cfg.defaults && cfg.defaults.date_posted_max_days) ?? 14;
  document.querySelector('[data-path="defaults.exclude_keywords"]').value =
    listToLines(cfg.defaults && cfg.defaults.exclude_keywords);

  // Searches
  const list = document.getElementById("searches-list");
  list.innerHTML = "";
  if (!cfg.searches || cfg.searches.length === 0) {
    list.innerHTML = '<div class="empty-state">Noch keine Suchen konfiguriert.</div>';
    return;
  }
  cfg.searches.forEach(s => list.appendChild(buildSearchCard(s)));
}

function buildSearchCard(search) {
  const tpl = document.getElementById("search-card-template");
  const node = tpl.content.firstElementChild.cloneNode(true);
  node.querySelector(".name").value = search.name || "";
  node.querySelector(".keywords").value = listToLines(search.keywords);
  node.querySelector(".exclude").value = listToLines(search.exclude_keywords);
  const boards = new Set(search.boards || []);
  node.querySelectorAll(".board").forEach(cb => { cb.checked = boards.has(cb.value); });

  node.querySelector(".del-btn").addEventListener("click", () => {
    if (confirm(`Suche "${node.querySelector(".name").value || "(unbenannt)"}" loeschen?`)) {
      node.remove();
      setDirty(true);
      ensureEmptyState();
    }
  });
  node.querySelector(".dup-btn").addEventListener("click", () => {
    const copy = collectCardData(node);
    copy.name = (copy.name || "Neue Suche") + " (Kopie)";
    node.parentNode.insertBefore(buildSearchCard(copy), node.nextSibling);
    setDirty(true);
  });
  node.querySelector(".gen-kw-btn").addEventListener("click", () => kwOpen(node));

  return node;
}

function ensureEmptyState() {
  const list = document.getElementById("searches-list");
  if (list.querySelectorAll(".search-card").length === 0) {
    list.innerHTML = '<div class="empty-state">Noch keine Suchen konfiguriert.</div>';
  }
}

function collectCardData(card) {
  return {
    name: card.querySelector(".name").value.trim(),
    keywords: linesToList(card.querySelector(".keywords").value),
    boards: Array.from(card.querySelectorAll(".board:checked")).map(cb => cb.value),
    exclude_keywords: linesToList(card.querySelector(".exclude").value),
  };
}

function collectFormConfig() {
  return {
    defaults: {
      locations: linesToList(document.querySelector('[data-path="defaults.locations"]').value),
      date_posted_max_days: parseInt(document.querySelector('[data-path="defaults.date_posted_max_days"]').value, 10) || 14,
      exclude_keywords: linesToList(document.querySelector('[data-path="defaults.exclude_keywords"]').value),
    },
    searches: Array.from(document.querySelectorAll(".search-card")).map(collectCardData),
  };
}

document.getElementById("add-btn").addEventListener("click", () => {
  const list = document.getElementById("searches-list");
  const empty = list.querySelector(".empty-state");
  if (empty) empty.remove();
  const card = buildSearchCard({
    name: "", keywords: [], boards: ["arbeitsagentur"], exclude_keywords: [],
  });
  // Neue Card vor die erste setzen + dezent hervorheben, damit sie auffaellt
  card.classList.add("search-card--new");
  card.addEventListener("animationend", () => card.classList.remove("search-card--new"), {once: true});
  list.prepend(card);
  card.scrollIntoView({behavior: "smooth", block: "nearest"});
  card.querySelector(".name").focus();
  setDirty(true);
});

document.getElementById("reload-btn").addEventListener("click", async () => {
  if (dirty && !confirm("Ungespeicherte Aenderungen verwerfen?")) return;
  await reloadFromServer();
});

document.getElementById("save-btn").addEventListener("click", async () => {
  const cfg = collectFormConfig();
  setStatus("", "");
  try {
    const resp = await fetch("/api/searches", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify(cfg),
    });
    const body = await resp.json();
    if (!resp.ok) {
      setStatus("error", "Validierungs-Fehler: " + (body.error || JSON.stringify(body)));
      return;
    }
    initialConfig = cfg;
    setDirty(false);
    setStatus("ok", "✓ Gespeichert. Diese Konfiguration gilt beim naechsten `bewerber discover`-Lauf.");
  } catch (e) {
    setStatus("error", "Netzfehler: " + e.message);
  }
});

async function reloadFromServer() {
  try {
    const resp = await fetch("/api/searches");
    const cfg = await resp.json();
    initialConfig = cfg;
    renderConfig(cfg);
    setDirty(false);
    setStatus("", "");
  } catch (e) {
    setStatus("error", "Konnte Konfiguration nicht laden: " + e.message);
  }
}

document.addEventListener("input", e => {
  if (e.target.closest("main")) setDirty(true);
});
document.addEventListener("change", e => {
  if (e.target.closest("main")) setDirty(true);
});

window.addEventListener("beforeunload", e => {
  if (dirty) { e.preventDefault(); e.returnValue = ""; }
});

renderConfig(initialConfig);
setDirty(false);

// --- Keyword-Varianten-Modal ---
let kwActiveCard = null;
let kwReqSeq = 0;   // invalidates in-flight generate requests when the modal state changes

function kwOpen(card) {
  kwReqSeq++;
  kwActiveCard = card;
  document.getElementById("kw-desc").value = "";
  document.getElementById("kw-manual").value = "";
  document.getElementById("kw-mode-generate").checked = true;
  document.getElementById("kw-mode-manual").checked = false;
  document.getElementById("kw-manual").style.display = "none";
  document.getElementById("kw-desc").style.display = "";
  document.getElementById("kw-suggestions").innerHTML = "";
  document.getElementById("kw-status").textContent = "";
  document.getElementById("kw-generate").style.display = "";
  document.getElementById("kw-generate").disabled = false;
  document.getElementById("kw-apply").style.display = "none";
  const linkedinOn = Array.from(card.querySelectorAll(".board:checked")).some(cb => cb.value === "linkedin");
  document.getElementById("kw-linkedin-hint").style.display = linkedinOn ? "" : "none";
  document.getElementById("kw-modal").style.display = "flex";
}

function kwClose() {
  kwReqSeq++;
  document.getElementById("kw-modal").style.display = "none";
  kwActiveCard = null;
}

document.getElementById("kw-mode-generate").addEventListener("change", e => {
  document.getElementById("kw-desc").style.display = e.target.checked ? "" : "none";
});
document.getElementById("kw-mode-manual").addEventListener("change", e => {
  document.getElementById("kw-manual").style.display = e.target.checked ? "" : "none";
});
document.getElementById("kw-cancel").addEventListener("click", kwClose);
document.getElementById("kw-modal").addEventListener("click", e => {
  if (e.target.id === "kw-modal") kwClose();
});

document.getElementById("kw-generate").addEventListener("click", async () => {
  const genOn = document.getElementById("kw-mode-generate").checked;
  const status = document.getElementById("kw-status");
  const suggestions = document.getElementById("kw-suggestions");
  suggestions.innerHTML = "";

  if (!genOn) {
    // Nur eigene Keywords -> direkt Übernehmen-Modus
    status.textContent = "";
    document.getElementById("kw-generate").style.display = "none";
    document.getElementById("kw-apply").style.display = "";
    return;
  }

  const seeds = [];
  const name = kwActiveCard.querySelector(".name").value.trim();
  if (name) seeds.push(name);
  seeds.push(...linesToList(kwActiveCard.querySelector(".keywords").value));
  const description = document.getElementById("kw-desc").value.trim();

  const myReq = ++kwReqSeq;
  status.textContent = "Generiere Varianten …";
  document.getElementById("kw-generate").disabled = true;
  try {
    const resp = await fetch("/api/keywords/generate", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify({seeds, description}),
    });
    const body = await resp.json();
    if (myReq !== kwReqSeq) return;   // modal moved on (closed/reopened) - drop stale response
    if (!resp.ok) {
      status.textContent = "Fehler: " + (body.error || resp.status);
      return;
    }
    renderSuggestions(body.variants || []);
    status.textContent = (body.variants || []).length
      ? `${body.variants.length} Vorschläge — abwählen, was nicht passt.`
      : "Keine neuen Varianten gefunden.";
    document.getElementById("kw-generate").style.display = "none";
    document.getElementById("kw-apply").style.display = "";
  } catch (e) {
    if (myReq === kwReqSeq) status.textContent = "Netzfehler: " + e.message;
  } finally {
    if (myReq === kwReqSeq) document.getElementById("kw-generate").disabled = false;
  }
});

function renderSuggestions(variants) {
  const box = document.getElementById("kw-suggestions");
  box.innerHTML = "";
  const groups = {};
  variants.forEach(v => { (groups[v.kategorie] = groups[v.kategorie] || []).push(v.keyword); });
  Object.keys(groups).forEach(cat => {
    const title = document.createElement("div");
    title.className = "kw-group-title";
    title.textContent = cat;
    box.appendChild(title);
    groups[cat].forEach(kw => {
      const label = document.createElement("label");
      label.className = "kw-item";
      const cb = document.createElement("input");
      cb.type = "checkbox";
      cb.checked = true;
      cb.value = kw;
      cb.className = "kw-suggest";
      label.appendChild(cb);
      label.appendChild(document.createTextNode(" " + kw));
      box.appendChild(label);
    });
  });
}

document.getElementById("kw-apply").addEventListener("click", () => {
  const ta = kwActiveCard.querySelector(".keywords");
  const existing = linesToList(ta.value);
  const seen = new Set(existing.map(k => k.toLowerCase()));
  const additions = [];

  Array.from(document.querySelectorAll("#kw-suggestions .kw-suggest:checked"))
    .forEach(cb => additions.push(cb.value));
  if (document.getElementById("kw-mode-manual").checked) {
    additions.push(...linesToList(document.getElementById("kw-manual").value));
  }

  let added = 0;
  additions.forEach(kw => {
    const key = kw.toLowerCase();
    if (kw && !seen.has(key)) { seen.add(key); existing.push(kw); added++; }
  });

  if (added > 0) {
    ta.value = listToLines(existing);
    setDirty(true);
  }
  kwClose();
});
</script>
</body>
</html>
