{# Macros: deutsche Monatsformatierung "2026-01" → "Jan 2026" #}
{%- set MONATE_DE = ["", "Jan", "Feb", "Mär", "Apr", "Mai", "Jun", "Jul", "Aug", "Sep", "Okt", "Nov", "Dez"] -%}
{%- macro fmt_ym(s) -%}
{%- if not s -%}{%- else -%}
{%- set parts = s.split("-") -%}
{%- if parts | length == 2 -%}{{ MONATE_DE[parts[1] | int] }} {{ parts[0] }}{%- else -%}{{ s }}{%- endif -%}
{%- endif -%}
{%- endmacro -%}
{%- macro fmt_year(s) -%}
{%- if not s -%}{%- else -%}{{ s.split("-")[0] }}{%- endif -%}
{%- endmacro -%}
{%- set th = theme or {
  "font_stack": '"Calibri","Carlito","Helvetica Neue","Arial",sans-serif',
  "accent_color": "#1f6feb", "text_color": "#20242b", "heading_color": "#1f6feb",
  "header_style": "left_accent_bar", "section_title_style": "uppercase_bar",
  "section_order": ["profil","skills","werdegang","projekte","bildung","sprachen","zertifikate"],
  "density": "normal"
} -%}
{%- set _gap = {"compact":"10pt","normal":"14pt","spacious":"18pt"}[th.density] -%}
<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8">
<title>Lebenslauf {{ profile.person.name }}</title>
<style>
/* set: base */
@page { size: A4; margin: 1.6cm 1.8cm 1.4cm 1.8cm;
  @bottom-right { content: "Seite " counter(page) " von " counter(pages); font-size: 8.5pt; color: #9aa0a6; } }
* { box-sizing: border-box; }
body { font-family: {{ th.font_stack }}; font-size: 10pt; line-height: 1.5; color: {{ th.text_color }}; margin: 0; }
.header { margin-bottom: 10pt; }
.header.centered { text-align: center; }
.header.left { text-align: left; }
.header.left_accent_bar { text-align: left; border-left: 4pt solid {{ th.accent_color }}; padding-left: 12pt; }
.name { font-size: 26pt; font-weight: 700; margin: 0 0 2pt 0; color: {{ th.heading_color }}; }
.subtitle { font-size: 12pt; font-weight: 600; color: {{ th.accent_color }}; margin: 0 0 4pt 0; }
.address { font-size: 9.5pt; color: #5f6671; margin: 0; }
.contact-line { display: flex; gap: 1.5em; margin: 6pt 0 10pt 0; font-size: 9.5pt; }
.section-divider { margin: {{ _gap }} 0 6pt 0; }
.section-title { font-weight: 700; font-size: 11pt; letter-spacing: 0.6pt; color: {{ th.heading_color }}; }
.section-title.uppercase_underline { text-transform: uppercase; text-decoration: underline; }
.section-title.uppercase_bar { text-transform: uppercase; border-bottom: 1.5pt solid {{ th.accent_color }}; padding-bottom: 2pt; }
.section-title.plain_bold { text-transform: none; }
.profile-text { margin: 4pt 0 8pt 0; }
.skill-cat { margin: 0 0 4pt 0; } .skill-cat-label { font-weight: 700; color: {{ th.heading_color }}; }
.werdegang-entry { margin: 6pt 0 8pt 0; page-break-inside: avoid; }
.werdegang-head { display: flex; justify-content: space-between; align-items: baseline; }
.werdegang-title { font-weight: 700; font-size: 10.5pt; flex: 1; padding-right: 8pt; }
.werdegang-title .firma { color: {{ th.accent_color }}; }
.werdegang-date { font-size: 9.5pt; color: #5f6671; white-space: nowrap; }
ul.bullets { margin: 4pt 0 0 1.4em; padding: 0; } ul.bullets li { margin-bottom: 2pt; }
.projektstelle { margin: 10pt 0 0 0; } .projektstelle-period { font-weight: 700; font-size: 10pt; color: #5f6671; }
.projektstelle-header { font-weight: 700; font-size: 10.5pt; margin: 0 0 4pt 0; }
.projektblock { margin: 6pt 0 8pt 0; page-break-inside: avoid; } .projektblock-title { font-weight: 700; font-size: 10pt; color: {{ th.heading_color }}; }
.ergebnis { font-weight: 700; list-style: none; }
.bildung-entry { display: flex; justify-content: space-between; margin: 4pt 0; page-break-inside: avoid; }
.bildung-institution { font-weight: 700; } .bildung-abschluss { font-style: italic; font-size: 9.5pt; color: #5f6671; }
.sprachen-row { display: flex; gap: 1.5em; flex-wrap: wrap; margin: 6pt 0; } .sprachen-row > div { flex: 1; min-width: 8em; }
.zertifikate-list { margin: 4pt 0 0 0; padding: 0; list-style: none; } .zertifikate-list li { font-weight: 700; margin: 3pt 0; }
.section-divider { page-break-after: avoid; } p, li { orphans: 2; widows: 2; }
</style>
</head>
<body>

<div class="header {{ th.header_style }}">
  <div class="name">{{ profile.person.name }}</div>
  <div class="subtitle">{{ zielposition_titel or "Projekt- und Prozessmanager" }}</div>
  {% if profile.person.adresse %}<div class="address">{{ profile.person.adresse }}</div>{% endif %}
</div>
<div class="contact-line">
  <span>{{ profile.person.phone or "" }}</span>
  <span>{{ profile.person.email or "" }}</span>
</div>

{# ---- Section macros ---- #}
{% macro sec_profil() %}
<div class="section-divider"><div class="section-title {{ th.section_title_style }}">{{ lbl.profil }}</div></div>
<p class="profile-text">{{ customized.berufsprofil_zugespitzt or profile.berufsprofil }}</p>
{% endmacro %}

{% macro sec_skills() %}
<div class="section-divider"><div class="section-title {{ th.section_title_style }}">{{ lbl.skills }}</div></div>
{% set sk = customized.skills_kategorisiert %}
{% if sk.prozessmanagement %}<div class="skill-cat"><span class="skill-cat-label">{{ lbl.sk_prozess }}:</span> {{ sk.prozessmanagement | join(", ") }}</div>{% endif %}
{% if sk.projektmanagement %}<div class="skill-cat"><span class="skill-cat-label">{{ lbl.sk_projekt }}:</span> {{ sk.projektmanagement | join(", ") }}</div>{% endif %}
{% if sk.kommunikation_training %}<div class="skill-cat"><span class="skill-cat-label">{{ lbl.sk_komm }}:</span> {{ sk.kommunikation_training | join(", ") }}</div>{% endif %}
{% if sk.automatisierung_ki %}<div class="skill-cat"><span class="skill-cat-label">{{ lbl.sk_auto }}:</span> {{ sk.automatisierung_ki | join(", ") }}</div>{% endif %}
{% if sk.vertrieb %}<div class="skill-cat"><span class="skill-cat-label">{{ lbl.sk_vertrieb }}:</span> {{ sk.vertrieb | join(", ") }}</div>{% endif %}
{% endmacro %}

{% macro sec_werdegang() %}
<div class="section-divider"><div class="section-title {{ th.section_title_style }}">{{ lbl.werdegang }}</div></div>
{% for job in customized.berufserfahrung %}
<div class="werdegang-entry">
  <div class="werdegang-head">
    <div class="werdegang-title">{{ job.position }}{% if job.firma %}, <span class="firma">{{ job.firma }}</span>{% endif %}</div>
    <div class="werdegang-date">{{ fmt_ym(job.von) }} - {% if job.bis %}{{ fmt_ym(job.bis) }}{% else %}{{ lbl.heute }}{% endif %}</div>
  </div>
  {% if job.werdegang_bullets %}
  <ul class="bullets">
    {% for bullet in job.werdegang_bullets %}<li>{{ bullet }}</li>{% endfor %}
  </ul>
  {% endif %}
</div>
{% endfor %}
{% endmacro %}

{% macro sec_projekte() %}
{# Detaillierte Projekterfahrung - nur Stellen mit projekterfahrung-Blöcken #}
{% set has_detail = customized.berufserfahrung | selectattr("projekterfahrung") | list | length > 0 %}
{% if has_detail %}
<div class="section-divider"><div class="section-title {{ th.section_title_style }}">{{ lbl.projekte }}</div></div>
{% for job in customized.berufserfahrung %}
{% if job.projekterfahrung %}
<div class="projektstelle">
  <div class="projektstelle-period">[{{ fmt_year(job.von) }}{% if job.bis %} - {{ fmt_year(job.bis) }}{% else %} - {{ lbl.heute }}{% endif %}]</div>
  <div class="projektstelle-header">{{ job.position }}{% if job.firma %} - {{ job.firma }}{% endif %}{% if job.standort %} ({{ job.standort }}){% endif %}</div>
  {% for block in job.projekterfahrung %}
  <div class="projektblock">
    <div class="projektblock-title">{{ block.titel }}</div>
    {% if block.aufgaben or block.ergebnisse %}
    <ul class="bullets">
      {% for a in block.aufgaben %}<li>{{ a }}</li>{% endfor %}
      {% for e in block.ergebnisse %}<li class="ergebnis">➔ {{ lbl.ergebnis }}: {{ e }}</li>{% endfor %}
    </ul>
    {% endif %}
  </div>
  {% endfor %}
</div>
{% endif %}
{% endfor %}
{% endif %}
{% endmacro %}

{% macro sec_bildung() %}
<div class="section-divider"><div class="section-title {{ th.section_title_style }}">{{ lbl.bildung }}</div></div>
{% for edu in profile.ausbildung %}
<div class="bildung-entry">
  <div class="bildung-left">
    <div class="bildung-institution">{{ edu.institution }}</div>
    {% if edu.abschluss %}<div class="bildung-abschluss">{{ edu.abschluss }}</div>{% endif %}
  </div>
  <div class="bildung-date">{{ edu.jahr or "" }}</div>
</div>
{% endfor %}
{% endmacro %}

{% macro sec_sprachen() %}
{% if profile.sprachen %}
<div class="section-divider"><div class="section-title {{ th.section_title_style }}">{{ lbl.sprachen }}</div></div>
<div class="sprachen-row">
  {% for s in profile.sprachen %}<div>{{ s.sprache }} ............... {{ s.niveau }}</div>{% endfor %}
</div>
{% endif %}
{% endmacro %}

{% macro sec_zertifikate() %}
{% if profile.zertifikate %}
<div class="section-divider"><div class="section-title {{ th.section_title_style }}">{{ lbl.zertifikate }}</div></div>
<ul class="zertifikate-list">
{% for z in profile.zertifikate %}<li>{{ z.name }}</li>{% endfor %}
</ul>
{% endif %}
{% endmacro %}

{# ---- Section order dispatch ---- #}
{% for _s in th.section_order %}
  {% if _s == "profil" %}{{ sec_profil() }}
  {% elif _s == "skills" %}{{ sec_skills() }}
  {% elif _s == "werdegang" %}{{ sec_werdegang() }}
  {% elif _s == "projekte" %}{{ sec_projekte() }}
  {% elif _s == "bildung" %}{{ sec_bildung() }}
  {% elif _s == "sprachen" %}{{ sec_sprachen() }}
  {% elif _s == "zertifikate" %}{{ sec_zertifikate() }}
  {% endif %}
{% endfor %}

</body>
</html>
