<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8">
<title>Anlagen verwalten - Bewerber</title>
{% include "_organic_ds.html.j2" %}
<style>
  header {
    position: sticky; top: 0; z-index: 10;
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--color-divider);
    padding: var(--space-3) var(--space-4);
    display: flex; align-items: center; gap: var(--space-4);
  }
  header h1 { margin: 0; font-size: 22px; flex: 1; }
  header a.back { color: inherit; text-decoration: none; font-size: 14px; }
  header a.back:hover { color: var(--color-accent); }
  .toolbar { display: flex; gap: var(--space-2); }
  main { max-width: 880px; margin: var(--space-6) auto; padding: 0 var(--space-4); }
  section.card { margin-bottom: var(--space-4); }
  section.card > h2 { font-size: 24px; margin: 0; display: flex; justify-content: space-between; align-items: center; gap: var(--space-2); }
  label.field { display: block; margin: var(--space-3) 0; font-size: 13px; }
  label.field > span { display: block; margin-bottom: 4px; font-weight: 600; }
  label.field > small { display: block; color: color-mix(in srgb, var(--color-text) 55%, transparent); font-size: 11px; margin-bottom: 4px; }
  textarea.input { font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 13px; border-radius: var(--radius-lg); min-height: 60px; }
  .anlage-card {
    border: 1px solid var(--color-divider); border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4); margin: var(--space-3) 0;
    background: color-mix(in srgb, var(--color-surface) 55%, transparent);
  }
  .anlage-card .head { display: flex; gap: var(--space-2); align-items: center; margin-bottom: var(--space-2); }
  .anlage-card .head input.label-input { flex: 1; font-weight: 600; font-size: 14px; }
  .file-status { font-size: 12px; margin-top: 6px; padding: 8px 14px; border-radius: var(--radius-md); display: none; white-space: pre-wrap; font-family: ui-monospace, "SF Mono", Menlo, monospace; }
  .file-status.ok { display: block; background: var(--color-accent-2-100); color: var(--color-accent-2-800); }
  .file-status.warn { display: block; background: var(--color-accent-100); color: var(--color-accent-700); }
  .file-status.err { display: block; background: var(--color-accent-100); color: var(--color-accent-800); }
  .empty-state { padding: var(--space-6); text-align: center; color: color-mix(in srgb, var(--color-text) 50%, transparent); font-style: italic; }
  #status { padding: 10px 18px; border-radius: var(--radius-md); margin-bottom: var(--space-3); display: none; }
  #status.ok { display: block; background: var(--color-accent-2-100); color: var(--color-accent-2-800); }
  #status.error { display: block; background: var(--color-accent-100); color: var(--color-accent-800); white-space: pre-wrap; }
  .dirty-flag { color: var(--color-accent-600); font-size: 12px; font-family: var(--font-body); }
  .hint { color: color-mix(in srgb, var(--color-text) 60%, transparent); font-size: 12px; margin-top: var(--space-2); line-height: 1.5; }
  .upload-box { margin: var(--space-3) 0; padding: var(--space-3); border: 1.5px dashed var(--color-divider); border-radius: var(--radius-lg); display: flex; align-items: center; gap: var(--space-2); flex-wrap: wrap; }
  .upload-box label { font-weight: 600; font-size: 13px; }
</style>
</head>
<body>
<header>
  <a class="back" href="/">← Dashboard</a>
  <h1>Anlagen verwalten <span id="dirty" class="dirty-flag" style="display:none;"> (ungespeicherte Aenderungen)</span></h1>
  <div class="toolbar">
    <button class="btn btn-secondary" id="reload-btn" title="Aenderungen verwerfen">↺ Neu laden</button>
    <button class="btn btn-primary" id="save-btn" disabled>Speichern</button>
  </div>
</header>

<main>
  <div id="status"></div>

  <section class="card elev-sm">
    <h2>
      Anlagen
      <button class="btn btn-secondary" id="add-btn">+ Anlage hinzufuegen</button>
    </h2>
    <p class="hint">
      Hinterlege hier die Dateien (Zeugnisse, Urkunden), die bei jeder erstellten
      Bewerbung automatisch in den Bewerbungsordner kopiert werden. Die Labels
      erscheinen im Anlagen-Block des Anschreibens. "Lebenslauf" wird automatisch
      vorangestellt - hier NICHT eintragen. Einfachster Weg: PDFs unten hochladen -
      sie werden in deinem Bereich gespeichert und automatisch als Anlage eingetragen.
    </p>
    <div class="upload-box">
      <label>Dateien hochladen (PDF) - werden automatisch als Anlage eingetragen:
        <input type="file" id="anlagen-upload" multiple accept="application/pdf">
      </label>
      <button class="btn btn-secondary" type="button" id="anlagen-upload-btn" onclick="uploadAnlagen()">Hochladen</button>
      <span id="anlagen-upload-status" style="font-size:12px;"></span>
    </div>
    <div id="anlagen-list">
      <div class="empty-state">Noch keine Anlagen konfiguriert.</div>
    </div>
  </section>
</main>

<template id="anlage-card-template">
  <div class="anlage-card">
    <div class="head">
      <input type="text" class="input label-input" placeholder="Label (z.B. Arbeitszeugnisse, Technikerzeugnis)" required>
      <button class="btn btn-secondary verify-btn" type="button" title="Existenz pruefen" style="font-size:12px;">Pruefen</button>
      <button class="btn btn-icon btn-secondary dup-btn" type="button" title="Duplizieren">⧉</button>
      <button class="btn btn-icon btn-secondary del-btn" type="button" title="Loeschen" style="color: var(--color-accent-800);">✕</button>
    </div>
    <label class="field">
      <span>Dateien</span>
      <small>Eine Datei pro Zeile - hochgeladene Dateien stehen hier automatisch (Pfad "anlagen/..."). Mehrere Zeilen unter einem Label, wenn ein Dokument auf mehrere PDFs verteilt ist (z.B. Technikerzeugnis Seite 1 + 2). Fortgeschritten: absolute Server-Pfade sind weiterhin moeglich.</small>
      <textarea class="input files-input" rows="3" placeholder="/absoluter/Pfad/zu/deinem/_anlagen/Arbeitszeugnis.pdf"></textarea>
    </label>
    <div class="file-status"></div>
  </div>
</template>

<script id="initial-config" type="application/json">{{ config_json }}</script>
<script>
let initialConfig = JSON.parse(document.getElementById("initial-config").textContent);
let dirty = false;

function linesToList(s) {
  return (s || "").split("\n").map(l => l.trim()).filter(Boolean);
}
function listToLines(arr) {
  return Array.isArray(arr) ? arr.join("\n") : "";
}
function setDirty(v) {
  dirty = v;
  document.getElementById("dirty").style.display = v ? "" : "none";
  document.getElementById("save-btn").disabled = !v;
}
function setStatus(kind, msg) {
  const el = document.getElementById("status");
  el.className = kind;
  el.textContent = msg;
  if (!msg) el.style.display = "none";
}

function renderConfig(cfg) {
  const list = document.getElementById("anlagen-list");
  list.innerHTML = "";
  if (!cfg.anlagen || cfg.anlagen.length === 0) {
    list.innerHTML = '<div class="empty-state">Noch keine Anlagen konfiguriert.</div>';
    return;
  }
  cfg.anlagen.forEach(a => list.appendChild(buildCard(a)));
}

function buildCard(anlage) {
  const tpl = document.getElementById("anlage-card-template");
  const node = tpl.content.firstElementChild.cloneNode(true);
  node.querySelector(".label-input").value = anlage.label || "";
  node.querySelector(".files-input").value = listToLines(anlage.files);

  node.querySelector(".del-btn").addEventListener("click", () => {
    if (confirm(`Anlage "${node.querySelector(".label-input").value || "(unbenannt)"}" loeschen?`)) {
      node.remove();
      setDirty(true);
      ensureEmptyState();
    }
  });
  node.querySelector(".dup-btn").addEventListener("click", () => {
    const copy = collectCardData(node);
    copy.label = (copy.label || "Neue Anlage") + " (Kopie)";
    node.parentNode.insertBefore(buildCard(copy), node.nextSibling);
    setDirty(true);
  });
  node.querySelector(".verify-btn").addEventListener("click", () => verifyCard(node));

  return node;
}

function ensureEmptyState() {
  const list = document.getElementById("anlagen-list");
  if (list.querySelectorAll(".anlage-card").length === 0) {
    list.innerHTML = '<div class="empty-state">Noch keine Anlagen konfiguriert.</div>';
  }
}

function collectCardData(card) {
  return {
    label: card.querySelector(".label-input").value.trim(),
    files: linesToList(card.querySelector(".files-input").value),
  };
}

function collectFormConfig() {
  return {
    anlagen: Array.from(document.querySelectorAll(".anlage-card")).map(collectCardData),
  };
}

async function verifyCard(card) {
  const statusEl = card.querySelector(".file-status");
  const paths = linesToList(card.querySelector(".files-input").value);
  if (paths.length === 0) {
    statusEl.className = "file-status warn";
    statusEl.textContent = "Keine Pfade angegeben.";
    return;
  }
  statusEl.className = "file-status";
  statusEl.textContent = "Pruefe ...";
  statusEl.style.display = "block";
  try {
    const resp = await fetch("/api/anlagen/verify", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify({paths}),
    });
    const body = await resp.json();
    const lines = paths.map(p => {
      const ok = !body.missing.includes(p);
      return `${ok ? "✓" : "✗"}  ${p}`;
    });
    if (body.missing.length === 0) {
      statusEl.className = "file-status ok";
    } else if (body.missing.length === paths.length) {
      statusEl.className = "file-status err";
    } else {
      statusEl.className = "file-status warn";
    }
    statusEl.textContent = lines.join("\n");
  } catch (e) {
    statusEl.className = "file-status err";
    statusEl.textContent = "Pruefung fehlgeschlagen: " + e.message;
  }
}

document.getElementById("add-btn").addEventListener("click", () => {
  const list = document.getElementById("anlagen-list");
  const empty = list.querySelector(".empty-state");
  if (empty) empty.remove();
  list.appendChild(buildCard({label: "", files: []}));
  setDirty(true);
});

document.getElementById("reload-btn").addEventListener("click", async () => {
  if (dirty && !confirm("Ungespeicherte Aenderungen verwerfen?")) return;
  await reloadFromServer();
});

document.getElementById("save-btn").addEventListener("click", async () => {
  const cfg = collectFormConfig();
  setStatus("", "");
  try {
    const resp = await fetch("/api/anlagen", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify(cfg),
    });
    const body = await resp.json();
    if (!resp.ok) {
      setStatus("error", "Validierungs-Fehler: " + (body.error || JSON.stringify(body)));
      return;
    }
    initialConfig = cfg;
    setDirty(false);
    if (body.missing && body.missing.length) {
      setStatus("error", "✓ Gespeichert, aber folgende Dateien existieren nicht auf der Platte:\n" + body.missing.join("\n"));
    } else {
      setStatus("ok", `✓ Gespeichert. ${body.anlagen} Anlage(n). Beim naechsten tailor-Lauf werden die Dateien automatisch in den Bewerbungsordner kopiert.`);
    }
  } catch (e) {
    setStatus("error", "Netzfehler: " + e.message);
  }
});

async function reloadFromServer() {
  try {
    const resp = await fetch("/api/anlagen");
    const cfg = await resp.json();
    initialConfig = cfg;
    renderConfig(cfg);
    setDirty(false);
    setStatus("", "");
  } catch (e) {
    setStatus("error", "Konnte Konfiguration nicht laden: " + e.message);
  }
}

document.addEventListener("input", e => { if (e.target.closest("main")) setDirty(true); });
document.addEventListener("change", e => { if (e.target.closest("main")) setDirty(true); });

window.addEventListener("beforeunload", e => {
  if (dirty) { e.preventDefault(); e.returnValue = ""; }
});

renderConfig(initialConfig);
setDirty(false);

function onAnlagenUploaded(saved) {
  // Jede hochgeladene Datei direkt als Anlage-Karte eintragen (Label = Dateiname)
  const list = document.getElementById("anlagen-list");
  const empty = list.querySelector(".empty-state");
  if (empty) empty.remove();
  for (const rel of saved) {
    const base = rel.split("/").pop().replace(/\.pdf$/i, "").replace(/[_-]+/g, " ");
    list.appendChild(buildCard({label: base, files: [rel]}));
  }
  if (saved.length) setDirty(true);
}

async function uploadAnlagen() {
  const input = document.getElementById("anlagen-upload");
  if (!input.files.length) return;
  const fd = new FormData();
  for (const f of input.files) fd.append("files", f);
  const status = document.getElementById("anlagen-upload-status");
  status.textContent = "Lade hoch ...";
  try {
    const resp = await fetch("/api/anlagen/upload", {method: "POST", body: fd});
    const body = await resp.json();
    if (!resp.ok) { status.textContent = body.error || "Fehler"; return; }
    status.textContent = "Hochgeladen: " + body.saved.join(", ");
    onAnlagenUploaded(body.saved);
    input.value = "";
  } catch (e) { status.textContent = "Netzfehler: " + e.message; }
}
</script>
</body>
</html>
